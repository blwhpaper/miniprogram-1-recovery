/**app.wxss**/
page {
  --ui-color-primary: #2563eb;
  --ui-color-primary-soft: #eff6ff;
  --ui-color-primary-border: #cfe0ff;
  --ui-color-primary-strong: #1d4ed8;
  --ui-color-success: #10b981;
  --ui-color-success-soft: #ecfdf5;
  --ui-color-success-border: #a7f3d0;
  --ui-color-warning: #f59e0b;
  --ui-color-warning-soft: #fffbeb;
  --ui-color-warning-border: #fcd34d;
  --ui-color-danger: #ef4444;
  --ui-color-danger-soft: #fef2f2;
  --ui-color-danger-border: #fecaca;
  --ui-color-neutral-border: #e2e8f0;
  --ui-color-neutral-soft: #f1f5f9;
  --ui-color-text: #1e293b;
  --ui-color-text-secondary: #334155;
  --ui-color-text-muted: #64748b;
  --ui-color-text-weak: #94a3b8;
  --ui-color-page-bg: #f8fafc;
  --ui-color-card-bg: #ffffff;
  --ui-color-card-subtle: #f1f5f9;
  --ui-color-border: #e2e8f0;
  --ui-color-divider: #e2e8f0;
  --ui-radius-sm: 16rpx;
  --ui-radius-md: 32rpx;
  --ui-radius-lg: 48rpx;
  --ui-radius-pill: 999rpx;
  --ui-shadow-card: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --ui-shadow-soft: 0 4rpx 12rpx rgba(15, 23, 42, 0.03);
  --ui-space-1: 8rpx;
  --ui-space-2: 12rpx;
  --ui-space-3: 16rpx;
  --ui-space-4: 20rpx;
  --ui-space-5: 24rpx;
  --ui-space-6: 32rpx;
  --ui-space-7: 40rpx;
  --ui-page-padding: 32rpx;
  --ui-card-padding: 32rpx;
  --ui-font-xs: 22rpx;
  --ui-font-sm: 24rpx;
  --ui-font-md: 28rpx;
  --ui-font-base: 28rpx;
  --ui-font-lg: 32rpx;
  --ui-font-xl: 40rpx;
  --ui-font-hero: 44rpx;
  --ui-button-height: 96rpx;
  background: var(--ui-color-page-bg);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  color: var(--ui-color-text);
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
} 

button {
  background: initial;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  vertical-align: middle;
  text-align: center;
  line-height: 1.4;
  transition: all 0.2s ease;
}

.ui-btn-active {
  transform: scale(0.97);
  opacity: 0.9;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}

button[type="primary"] {
  height: var(--ui-button-height);
  line-height: 1.4;
  border-radius: var(--ui-radius-sm);
  background: var(--ui-color-primary);
  box-shadow: var(--ui-shadow-soft);
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: #ffffff;
}

button[type="primary"][disabled] {
  opacity: 0.55;
}

button[disabled] {
  opacity: 0.55;
}

button[size="mini"] {
  min-width: 0;
  height: 64rpx;
  line-height: 1.35;
  padding: 0 20rpx;
  font-size: var(--ui-font-sm);
  border-radius: 14rpx;
}

.ui-page {
  min-height: 100vh;
  padding: var(--ui-space-6) var(--ui-page-padding);
  padding-bottom: calc(var(--ui-space-6) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--ui-space-6) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ui-page--with-bottom-bar {
  padding-bottom: calc(168rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(168rpx + env(safe-area-inset-bottom));
}

.ui-page--center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ui-page--stack {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-5);
}

.ui-page-header {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-2);
}

.ui-page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.ui-page-head-main {
  flex: 1;
  min-width: 0;
}

.ui-page-head-badge {
  flex-shrink: 0;
  align-self: flex-start;
  max-width: 240rpx;
}

.ui-card {
  width: 100%;
  background: var(--ui-color-card-bg);
  border-radius: var(--ui-radius-md);
  padding: var(--ui-card-padding);
  box-sizing: border-box;
  box-shadow: var(--ui-shadow-card);
}

.ui-card--subtle {
  background: var(--ui-color-card-subtle);
  box-shadow: none;
  border: 1rpx solid var(--ui-color-divider);
}

.ui-card--info {
  background: var(--ui-color-primary-soft);
  box-shadow: none;
  border: 1rpx solid var(--ui-color-primary-border);
}

.ui-panel-card {
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.ui-panel-card--focus {
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.ui-panel-card--warning {
  background: var(--ui-color-warning-soft);
  border: 1rpx solid var(--ui-color-warning-border);
  box-shadow: none;
}

.ui-panel-card--empty {
  border: 1rpx dashed rgba(37, 99, 235, 0.2);
  box-shadow: none;
}

.ui-section {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-hero-card {
  padding: 40rpx 32rpx;
  border-radius: var(--ui-radius-lg);
  gap: var(--ui-space-4);
  position: relative;
  overflow: hidden;
}

.ui-hero-card--primary {
  background: linear-gradient(135deg, var(--ui-color-primary-soft) 0%, #ffffff 100%);
}

.ui-hero-card--primary::after {
  content: "";
  position: absolute;
  top: -20%;
  right: -10%;
  width: 240rpx;
  height: 240rpx;
  background: var(--ui-color-primary);
  opacity: 0.04;
  filter: blur(40rpx);
  border-radius: 50%;
  pointer-events: none;
}

.ui-hero-card--teacher {
  background: linear-gradient(135deg, #f0f4ff 0%, #ffffff 100%);
}

.ui-hero-card--teacher::after {
  content: "";
  position: absolute;
  top: -20%;
  right: -10%;
  width: 240rpx;
  height: 240rpx;
  background: #1e40af;
  opacity: 0.04;
  filter: blur(40rpx);
  border-radius: 50%;
  pointer-events: none;
}

.ui-status-card {
  border: 1rpx solid var(--ui-color-divider);
  box-shadow: none;
}

.ui-notice-card {
  background: var(--ui-color-neutral-soft);
  border: 1rpx solid var(--ui-color-divider);
  box-shadow: none;
}

.ui-hero-section {
  position: relative;
  margin: calc(-1 * var(--ui-space-6)) calc(-1 * var(--ui-page-padding)) 0;
  padding: calc(36rpx + constant(safe-area-inset-top)) var(--ui-page-padding) 40rpx;
  padding: calc(36rpx + env(safe-area-inset-top)) var(--ui-page-padding) 40rpx;
  background: linear-gradient(135deg, var(--ui-color-primary) 0%, #3b82f6 100%);
  border-radius: 0 0 var(--ui-radius-lg) var(--ui-radius-lg);
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.18);
  overflow: hidden;
  box-sizing: border-box;
}

.ui-hero-section::after {
  content: "";
  position: absolute;
  top: -88rpx;
  right: -44rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.ui-hero-section__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-4);
}

.ui-hero-section__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--ui-space-3);
}

.ui-hero-section__title {
  font-size: var(--ui-font-xl);
  font-weight: 700;
  line-height: 1.35;
  color: #ffffff;
}

.ui-hero-section__desc {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.ui-hero-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: var(--ui-radius-pill);
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: var(--ui-font-xs);
  font-weight: 600;
  box-sizing: border-box;
}

.ui-surface--info,
.ui-surface--success,
.ui-surface--warning,
.ui-surface--danger,
.ui-surface--neutral {
  box-shadow: none;
}

.ui-surface--info {
  background: var(--ui-color-primary-soft);
  border: 1rpx solid var(--ui-color-primary-border);
}

.ui-surface--success {
  background: var(--ui-color-success-soft);
  border: 1rpx solid var(--ui-color-success-border);
}

.ui-surface--warning {
  background: var(--ui-color-warning-soft);
  border: 1rpx solid var(--ui-color-warning-border);
}

.ui-surface--danger {
  background: var(--ui-color-danger-soft);
  border: 1rpx solid var(--ui-color-danger-border);
}

.ui-surface--neutral {
  background: var(--ui-color-neutral-soft);
  border: 1rpx solid var(--ui-color-neutral-border);
}

.ui-card-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ui-card-head--row {
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.ui-eyebrow {
  font-size: var(--ui-font-sm);
  font-weight: 600;
  color: var(--ui-color-text-muted);
}

.ui-title-hero {
  font-size: var(--ui-font-hero);
  font-weight: 700;
  line-height: 1.3;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-title-lg {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-title-md {
  font-size: var(--ui-font-lg);
  font-weight: 600;
  line-height: 1.5;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-text-body {
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-secondary);
  word-break: break-word;
}

.ui-text-muted {
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
  word-break: break-word;
}

.ui-text-helper {
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-weak);
  word-break: break-word;
}

.ui-divider {
  width: 100%;
  height: 1rpx;
  background: var(--ui-color-divider);
}

.ui-form-label {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.ui-form-card {
  gap: var(--ui-space-5);
}

.ui-form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ui-input,
.ui-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--ui-color-border);
  border-radius: var(--ui-radius-sm);
  background: var(--ui-color-card-subtle);
  font-size: var(--ui-font-base);
  color: var(--ui-color-text);
}

.ui-input[disabled],
.ui-textarea[disabled] {
  background: #f8fafc;
  color: var(--ui-color-text-muted);
  border-color: var(--ui-color-divider);
  opacity: 1;
}

.ui-input {
  height: var(--ui-button-height);
  padding: 0 24rpx;
  line-height: 1.4;
  box-sizing: border-box;
  vertical-align: middle;
  text-align: left;
}

input.ui-input {
  padding: 0 24rpx;
}

.ui-textarea {
  min-height: 180rpx;
  line-height: 1.6;
  padding: 20rpx 24rpx;
}

button.ui-btn-secondary,
button.ui-btn-ghost,
button.ui-btn-danger,
button.ui-btn-pill {
  height: var(--ui-button-height);
  line-height: 1.4;
  border-radius: var(--ui-radius-sm);
  font-size: var(--ui-font-base);
  font-weight: 600;
}

button[size="mini"].ui-btn-secondary,
button[size="mini"].ui-btn-ghost,
button[size="mini"].ui-btn-danger,
button[size="mini"].ui-btn-pill,
button[size="mini"][type="primary"] {
  height: 64rpx;
  line-height: 1.35;
  padding: 0 20rpx;
  font-size: var(--ui-font-sm);
  border-radius: 14rpx;
}

button.ui-btn-secondary {
  background: var(--ui-color-primary-soft);
  color: var(--ui-color-primary-strong);
}

button.ui-btn-ghost {
  background: #ffffff;
  color: var(--ui-color-text-secondary);
  border: 1rpx solid var(--ui-color-border);
}

button.ui-btn-danger {
  background: var(--ui-color-danger);
  color: #ffffff;
}

button.ui-btn-pill {
  background: var(--ui-color-primary-soft);
  color: var(--ui-color-primary);
  border: 1rpx solid var(--ui-color-primary-border);
  border-radius: 999rpx;
}

button.ui-btn-pill.ui-btn-pill--warning {
  background: var(--ui-color-warning-soft);
  color: #9a6700;
  border-color: #ffd089;
}

button.ui-btn-pill.ui-btn-pill--danger {
  background: #fee2e2;
  color: #b91c1c;
  border-color: #fecaca;
}

button.ui-btn-pill.ui-btn-pill--selected {
  background: #f3e8ff;
  color: #7c3aed;
  border-color: #ddd6fe;
}

button.ui-btn-pill.ui-btn-pill--active {
  box-shadow: inset 0 0 0 1rpx rgba(37, 99, 235, 0.12);
}

button.ui-btn-pill.ui-btn-pill--active-danger {
  background: #fee2e2;
  color: #b91c1c;
  border-color: #fecaca;
}

button.ui-btn-pill.ui-btn-pill--disabled {
  opacity: 0.5;
}

button.ui-btn-secondary[disabled],
button.ui-btn-ghost[disabled],
button.ui-btn-danger[disabled],
button.ui-btn-pill[disabled] {
  opacity: 0.55;
}

.ui-button-group button,
.ui-record-actions button,
.ui-state-actions button {
  width: 100%;
  margin: 0;
  min-width: 0;
  min-height: var(--ui-button-height);
  height: auto;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
  text-align: center;
  white-space: normal;
  word-break: break-word;
}

.ui-button-group button[size="mini"],
.ui-record-actions button[size="mini"],
.ui-state-actions button[size="mini"] {
  min-height: 64rpx;
  padding: 12rpx 20rpx;
}

.ui-button-group {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--ui-space-3);
}

.ui-button-group--compact {
  gap: var(--ui-space-2);
}

.ui-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  max-width: 100%;
  padding: 0 16rpx;
  border-radius: var(--ui-radius-pill);
  font-size: var(--ui-font-xs);
  font-weight: 600;
  box-sizing: border-box;
  vertical-align: middle;
  line-height: 1.4;
  text-align: center;
  word-break: break-word;
}

.ui-tag--pending {
  background: var(--ui-color-warning-soft);
  color: var(--ui-color-warning);
}

.ui-tag--approved,
.ui-tag--active {
  background: var(--ui-color-success-soft);
  color: var(--ui-color-success);
}

.ui-tag--signed {
  background: var(--ui-color-success-soft);
  color: var(--ui-color-success);
}

.ui-tag--rejected,
.ui-tag--danger {
  background: var(--ui-color-danger-soft);
  color: var(--ui-color-danger);
}

.ui-tag--absent {
  background: var(--ui-color-danger-soft);
  color: var(--ui-color-danger);
}

.ui-tag--inactive,
.ui-tag--missing,
.ui-tag--muted,
.ui-tag--unsigned {
  background: var(--ui-color-card-subtle);
  color: var(--ui-color-text-muted);
}

.ui-tag--leave_wait {
  background: var(--ui-color-warning-soft);
  color: var(--ui-color-warning);
}

.ui-tag--leave_agree {
  background: #ede9fe;
  color: #6d28d9;
}

.ui-tag--degraded {
  background: #ede9fe;
  color: #6d28d9;
}

.ui-feedback {
  width: 100%;
  padding: 18rpx 20rpx;
  border-radius: var(--ui-radius-sm);
  box-sizing: border-box;
  font-size: var(--ui-font-sm);
  line-height: 1.65;
  word-break: break-word;
  border: 1rpx solid transparent;
}

.ui-feedback--neutral,
.ui-feedback--idle,
.ui-feedback--disabled {
  background: var(--ui-color-neutral-soft);
  color: var(--ui-color-text-muted);
  border-color: var(--ui-color-neutral-border);
}

.ui-feedback--info,
.ui-feedback--submitting {
  background: var(--ui-color-primary-soft);
  color: var(--ui-color-primary);
  border-color: var(--ui-color-primary-border);
}

.ui-feedback--success,
.ui-feedback--matched {
  background: var(--ui-color-success-soft);
  color: var(--ui-color-success);
  border-color: var(--ui-color-success-border);
}

.ui-feedback--warning {
  background: var(--ui-color-warning-soft);
  color: var(--ui-color-warning);
  border-color: var(--ui-color-warning-border);
}

.ui-feedback--danger,
.ui-feedback--error,
.ui-feedback--invalid,
.ui-feedback--not_found,
.ui-feedback--duplicate,
.ui-feedback--self {
  background: var(--ui-color-danger-soft);
  color: var(--ui-color-danger);
  border-color: var(--ui-color-danger-border);
}

.ui-empty-state {
  padding: 40rpx 24rpx;
  text-align: center;
}

.ui-empty-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ui-space-3);
}

.ui-empty-visual {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--ui-color-card-subtle) 100%);
  border: 1rpx solid var(--ui-color-border);
  box-shadow: var(--ui-shadow-soft);
}

.ui-empty-title,
.ui-state-title {
  font-size: var(--ui-font-md);
  font-weight: 600;
  line-height: 1.6;
  color: var(--ui-color-text);
}

.ui-empty-desc,
.ui-state-desc {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.ui-state-block {
  width: 100%;
  padding: 36rpx 28rpx;
  border-radius: var(--ui-radius-md);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ui-space-2);
  text-align: center;
}

.ui-loading-state {
  background: var(--ui-color-primary-soft);
  border: 1rpx solid var(--ui-color-primary-border);
}

.ui-error-state {
  background: var(--ui-color-danger-soft);
  border: 1rpx solid var(--ui-color-danger-border);
}

.ui-success-state {
  background: var(--ui-color-success-soft);
  border: 1rpx solid var(--ui-color-success-border);
}

.ui-warning-state {
  background: var(--ui-color-warning-soft);
  border: 1rpx solid var(--ui-color-warning-border);
}

.ui-state-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  justify-content: center;
  gap: var(--ui-space-3);
  margin-top: var(--ui-space-2);
}

.ui-state-note {
  font-size: var(--ui-font-xs);
  line-height: 1.6;
  color: var(--ui-color-text-weak);
}

.ui-info-list {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-info-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-4);
}

.ui-info-label {
  flex-shrink: 0;
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-muted);
}

.ui-info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-secondary);
  word-break: break-word;
}

.ui-stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ui-stat-card {
  flex: 1 1 220rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  box-sizing: border-box;
}

.ui-stat-label {
  font-size: 22rpx;
  color: var(--ui-color-text-muted);
}

.ui-stat-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ui-color-text);
  line-height: 1.5;
}

.ui-scroll-x {
  white-space: nowrap;
}

.ui-chip-list {
  display: flex;
  align-items: stretch;
  gap: var(--ui-space-3);
  padding-bottom: 4rpx;
}

.ui-chip-card {
  flex: 0 0 auto;
  min-width: 220rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: var(--ui-color-card-subtle);
  border: 1rpx solid transparent;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ui-chip-card--active {
  background: var(--ui-color-primary-soft);
  border-color: var(--ui-color-primary-border);
}

.ui-chip-title {
  display: block;
  font-size: var(--ui-font-sm);
  font-weight: 600;
  color: var(--ui-color-text);
}

.ui-chip-meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--ui-font-xs);
  color: var(--ui-color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ui-record-list {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-4);
}

.ui-record-card {
  background: var(--ui-color-card-bg);
  border-radius: var(--ui-radius-md);
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: var(--ui-shadow-soft);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ui-record-card--muted {
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.ui-record-card--info {
  border: 1rpx solid rgba(37, 99, 235, 0.18);
}

.ui-record-card--warning {
  border: 1rpx solid var(--ui-color-warning-border);
  background: var(--ui-color-warning-soft);
}

.ui-record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.ui-record-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: var(--ui-space-3);
}

.ui-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--ui-space-3);
}

.ui-action-tile {
  min-height: 152rpx;
  padding: 24rpx;
  border-radius: var(--ui-radius-md);
  background: var(--ui-color-card-bg);
  border: 1rpx solid var(--ui-color-border);
  box-shadow: var(--ui-shadow-soft);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.ui-action-tile__title {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.ui-action-tile__desc {
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-muted);
}

.ui-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 16rpx var(--ui-page-padding) calc(16rpx + constant(safe-area-inset-bottom));
  padding: 16rpx var(--ui-page-padding) calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(248, 250, 252, 0.96);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -6rpx 20rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.ui-bottom-bar__content {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-bottom-bar__hint {
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-muted);
  text-align: center;
}

.ui-bottom-bar__actions {
  display: flex;
  align-items: stretch;
  gap: var(--ui-space-3);
}

.ui-bottom-bar__actions button {
  flex: 1;
  margin: 0;
}

.ui-modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.42);
  z-index: 98;
}

.ui-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  background: var(--ui-color-card-bg);
  border-radius: 40rpx 40rpx 0 0;
  padding: 44rpx 40rpx calc(88rpx + constant(safe-area-inset-bottom));
  padding: 44rpx 40rpx calc(88rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  box-shadow: 0 -20rpx 48rpx rgba(15, 23, 42, 0.14);
}

.ui-sheet__close {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ui-sheet__close-icon {
  width: 32rpx;
  height: 32rpx;
}

.ui-sheet__body {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-sheet__title {
  font-size: var(--ui-font-xl);
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
  text-align: center;
}

.ui-sheet__content {
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
  word-break: break-word;
}
