/**app.wxss**/
page {
  --ui-color-primary: #2563eb;
  --ui-color-primary-soft: #eff6ff;
  --ui-color-primary-border: #cfe0ff;
  --ui-color-success: #16a34a;
  --ui-color-success-soft: #ecfdf3;
  --ui-color-warning: #d97706;
  --ui-color-warning-soft: #fff7ed;
  --ui-color-danger: #dc2626;
  --ui-color-danger-soft: #fef2f2;
  --ui-color-neutral-soft: #f8fafc;
  --ui-color-text: #111827;
  --ui-color-text-secondary: #374151;
  --ui-color-text-muted: #6b7280;
  --ui-color-text-weak: #9ca3af;
  --ui-color-page-bg: #f4f7fb;
  --ui-color-card-bg: #ffffff;
  --ui-color-card-subtle: #f8fafc;
  --ui-color-border: #dbe3f0;
  --ui-color-divider: #e5e7eb;
  --ui-radius-sm: 16rpx;
  --ui-radius-md: 24rpx;
  --ui-radius-lg: 36rpx;
  --ui-shadow-card: 0 14rpx 40rpx rgba(31, 41, 55, 0.08);
  --ui-shadow-soft: 0 8rpx 20rpx rgba(31, 41, 55, 0.05);
  --ui-space-1: 8rpx;
  --ui-space-2: 12rpx;
  --ui-space-3: 16rpx;
  --ui-space-4: 20rpx;
  --ui-space-5: 24rpx;
  --ui-space-6: 32rpx;
  --ui-space-7: 40rpx;
  --ui-font-xs: 22rpx;
  --ui-font-sm: 24rpx;
  --ui-font-md: 26rpx;
  --ui-font-base: 28rpx;
  --ui-font-lg: 30rpx;
  --ui-font-xl: 36rpx;
  --ui-font-hero: 42rpx;
  --ui-button-height: 88rpx;
  background: var(--ui-color-page-bg);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  color: var(--ui-color-text);
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
} 

button {
  background: initial;
  transition: all 0.2s ease;
}

.ui-btn-active {
  transform: scale(0.97);
  opacity: 0.9;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}

button[type="primary"] {
  height: var(--ui-button-height);
  line-height: var(--ui-button-height);
  border-radius: 22rpx;
  background: var(--ui-color-primary);
  box-shadow: var(--ui-shadow-soft);
  font-size: var(--ui-font-base);
  font-weight: 600;
}

button[type="primary"][disabled] {
  opacity: 0.55;
}

button[size="mini"] {
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: var(--ui-font-sm);
  border-radius: 14rpx;
}

.ui-page {
  min-height: 100vh;
  padding: var(--ui-space-7) var(--ui-space-6);
  padding-bottom: calc(var(--ui-space-7) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--ui-space-7) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ui-page--center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ui-page--stack {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-5);
}

.ui-page-header {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-2);
}

.ui-card {
  width: 100%;
  background: var(--ui-color-card-bg);
  border-radius: var(--ui-radius-md);
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: var(--ui-shadow-card);
}

.ui-card--subtle {
  background: var(--ui-color-card-subtle);
  box-shadow: none;
  border: 1rpx solid var(--ui-color-divider);
}

.ui-card--info {
  background: var(--ui-color-primary-soft);
  box-shadow: none;
  border: 1rpx solid var(--ui-color-primary-border);
}

.ui-section {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-hero-card {
  padding: 36rpx 32rpx;
  border-radius: var(--ui-radius-lg);
  gap: var(--ui-space-4);
}

.ui-status-card {
  border: 1rpx solid var(--ui-color-divider);
  box-shadow: none;
}

.ui-notice-card {
  background: var(--ui-color-neutral-soft);
  border: 1rpx solid var(--ui-color-divider);
  box-shadow: none;
}

.ui-card-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ui-card-head--row {
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.ui-eyebrow {
  font-size: var(--ui-font-sm);
  font-weight: 600;
  color: var(--ui-color-text-muted);
}

.ui-title-hero {
  font-size: var(--ui-font-hero);
  font-weight: 700;
  line-height: 1.3;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-title-lg {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-title-md {
  font-size: var(--ui-font-lg);
  font-weight: 600;
  line-height: 1.5;
  color: var(--ui-color-text);
  word-break: break-word;
}

.ui-text-body {
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-secondary);
  word-break: break-word;
}

.ui-text-muted {
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
  word-break: break-word;
}

.ui-text-helper {
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-weak);
  word-break: break-word;
}

.ui-divider {
  width: 100%;
  height: 1rpx;
  background: var(--ui-color-divider);
}

.ui-form-label {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.ui-form-card {
  gap: var(--ui-space-5);
}

.ui-form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ui-input,
.ui-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--ui-color-border);
  border-radius: var(--ui-radius-sm);
  background: var(--ui-color-card-bg);
  font-size: var(--ui-font-base);
  color: var(--ui-color-text);
}

.ui-input {
  height: var(--ui-button-height);
  line-height: var(--ui-button-height);
  padding: 0 24rpx;
}

.ui-textarea {
  min-height: 180rpx;
  line-height: 1.6;
  padding: 20rpx 24rpx;
}

button.ui-btn-secondary,
button.ui-btn-ghost,
button.ui-btn-danger {
  height: var(--ui-button-height);
  line-height: var(--ui-button-height);
  border-radius: 22rpx;
  font-size: var(--ui-font-base);
  font-weight: 600;
}

button[size="mini"].ui-btn-secondary,
button[size="mini"].ui-btn-ghost,
button[size="mini"].ui-btn-danger,
button[size="mini"][type="primary"] {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: var(--ui-font-sm);
  border-radius: 14rpx;
}

button.ui-btn-secondary {
  background: #e8f0ff;
  color: #1d4ed8;
}

button.ui-btn-ghost {
  background: #ffffff;
  color: var(--ui-color-text-secondary);
  border: 1rpx solid var(--ui-color-border);
}

button.ui-btn-danger {
  background: var(--ui-color-danger);
  color: #ffffff;
}

.ui-button-group button,
.ui-record-actions button,
.ui-state-actions button {
  width: 100%;
  margin: 0;
  min-width: 0;
  min-height: var(--ui-button-height);
  height: auto;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
  text-align: center;
  white-space: normal;
  word-break: break-word;
}

.ui-button-group button[size="mini"],
.ui-record-actions button[size="mini"],
.ui-state-actions button[size="mini"] {
  min-height: 64rpx;
  padding: 12rpx 20rpx;
}

.ui-button-group {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-button-group--compact {
  gap: var(--ui-space-2);
}

.ui-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  max-width: 100%;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: var(--ui-font-xs);
  font-weight: 600;
  box-sizing: border-box;
  line-height: 1.5;
  text-align: center;
  word-break: break-word;
}

.ui-tag--pending {
  background: var(--ui-color-warning-soft);
  color: var(--ui-color-warning);
}

.ui-tag--approved,
.ui-tag--active {
  background: var(--ui-color-success-soft);
  color: var(--ui-color-success);
}

.ui-tag--signed {
  background: var(--ui-color-success-soft);
  color: var(--ui-color-success);
}

.ui-tag--rejected,
.ui-tag--danger {
  background: var(--ui-color-danger-soft);
  color: var(--ui-color-danger);
}

.ui-tag--absent {
  background: var(--ui-color-danger-soft);
  color: var(--ui-color-danger);
}

.ui-tag--inactive,
.ui-tag--missing,
.ui-tag--muted,
.ui-tag--unsigned {
  background: #f3f4f6;
  color: var(--ui-color-text-muted);
}

.ui-tag--leave_wait {
  background: var(--ui-color-warning-soft);
  color: var(--ui-color-warning);
}

.ui-tag--leave_agree {
  background: #f3e8ff;
  color: #7c3aed;
}

.ui-tag--degraded {
  background: #ede9fe;
  color: #6d28d9;
}

.ui-empty-state {
  padding: 40rpx 24rpx;
  text-align: center;
}

.ui-empty-title,
.ui-state-title {
  font-size: var(--ui-font-md);
  font-weight: 600;
  line-height: 1.6;
  color: var(--ui-color-text);
}

.ui-empty-desc,
.ui-state-desc {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.ui-state-block {
  width: 100%;
  padding: 36rpx 28rpx;
  border-radius: var(--ui-radius-md);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ui-space-2);
  text-align: center;
}

.ui-loading-state {
  background: var(--ui-color-primary-soft);
  border: 1rpx solid var(--ui-color-primary-border);
}

.ui-error-state {
  background: var(--ui-color-danger-soft);
  border: 1rpx solid #fecaca;
}

.ui-state-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--ui-space-3);
  margin-top: var(--ui-space-2);
}

.ui-state-note {
  font-size: var(--ui-font-xs);
  line-height: 1.6;
  color: var(--ui-color-text-weak);
}

.ui-info-list {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.ui-info-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-4);
}

.ui-info-label {
  flex-shrink: 0;
  font-size: var(--ui-font-sm);
  line-height: 1.6;
  color: var(--ui-color-text-muted);
}

.ui-info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: var(--ui-font-md);
  line-height: 1.7;
  color: var(--ui-color-text-secondary);
  word-break: break-word;
}

.ui-chip-list {
  display: flex;
  gap: var(--ui-space-3);
  padding-bottom: 4rpx;
}

.ui-chip-card {
  flex: 0 0 auto;
  min-width: 220rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: var(--ui-color-card-subtle);
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.ui-chip-card--active {
  background: var(--ui-color-primary-soft);
  border-color: var(--ui-color-primary-border);
}

.ui-chip-title {
  display: block;
  font-size: var(--ui-font-sm);
  font-weight: 600;
  color: var(--ui-color-text);
}

.ui-chip-meta {
  display: block;
  margin-top: 8rpx;
  font-size: var(--ui-font-xs);
  color: var(--ui-color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ui-record-list {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-4);
}

.ui-record-card {
  background: var(--ui-color-card-bg);
  border-radius: var(--ui-radius-md);
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: var(--ui-shadow-soft);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ui-record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.ui-record-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}
