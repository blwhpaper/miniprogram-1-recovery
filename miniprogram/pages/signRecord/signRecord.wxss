.sign-record-page {
  align-items: stretch;
}

.export-actions {
  margin-top: 4rpx;
}

.export-btn {
  margin: 0;
  flex: 1 1 280rpx;
  min-width: 0;
}

.export-btn--disabled {
  opacity: 0.45;
  filter: grayscale(1);
}
.leave-img {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
}

.leave-action-btn {
  margin: 0;
}

.leave-action-btn--disabled {
  opacity: 0.45;
}

.attendance-btn {
  margin: 0;
  flex: 1 1 220rpx;
  min-width: 0;
}

.attendance-btn--disabled {
  opacity: 0.5;
}
