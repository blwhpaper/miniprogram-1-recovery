.sign-record-page {
  align-items: stretch;
}

.export-actions {
  margin-top: 4rpx;
}

.export-btn {
  margin: 0;
}

.export-btn--disabled {
  opacity: 0.45;
  filter: grayscale(1);
}
.lesson-scroll {
  white-space: nowrap;
}

.leave-img {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
}

.leave-action-btn {
  margin: 0;
}

.leave-action-btn--disabled {
  opacity: 0.45;
}

.attendance-btn {
  margin: 0;
  background: #eef4ff;
  color: #1d4ed8;
  border-radius: 999rpx;
}

.attendance-btn--leave.attendance-btn--active {
  background: #f3e8ff;
  color: #7c3aed;
}

.attendance-btn--absent.attendance-btn--active-danger {
  background: #fee2e2;
  color: #b91c1c;
}

.attendance-btn--disabled {
  opacity: 0.5;
}
