
<view class="page">
  <view class="stats-fixed">
    <view wx:if="{{currentStats}}" class="attendance-summary">
      <view class="attendance-summary-top">
        <view>
          <text class="attendance-summary-title">
            出勤：{{currentStats.signedCount}} / {{currentStats.rosterCount}}
          </text>
          <text class="attendance-summary-sub">
            未到：{{currentStats.unsignedCount}}
          </text>
        </view>
        <view class="export-btn-group">
          <button class="export-btn {{statsExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" bindtap="onTapExportLessonStats">导出全部课次统计</button>
          <button class="export-btn export-btn-secondary {{detailExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" bindtap="onTapExportLessonDetail">导出本次课明细</button>
        </view>
      </view>
    </view>

    <view class="lesson-section">
      <view class="lesson-header">
        <text class="lesson-title">历史课次</text>
      </view>

      <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll" scroll-x="true" show-scrollbar="false">
        <view class="lesson-list">
          <view
            wx:for="{{lessons}}"
            wx:key="_id"
            class="lesson-item {{selectedLessonId === item._id ? 'active' : ''}}"
            bindtap="onSelectLesson"
            data-lesson-id="{{item._id}}"
          >
            <text class="lesson-item-title">课次 {{lessons.length - index}}</text>
            <text class="lesson-item-id">{{item._id}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:else class="lesson-empty">暂无历史课次</view>
    </view>
  </view>

  <view class="list-container">
    <view wx:if="{{pendingLeaveRequests.length > 0}}" class="event-list">
      <view class="lesson-header">
        <text class="lesson-title">待处理请假申请</text>
      </view>
      <view class="event-item" wx:for="{{pendingLeaveRequests}}" wx:key="_id">
        <view class="info">
          <text class="name">{{item.studentName}}</text>
        </view>
        <view class="sub">
          <text>处理态：{{item.leaveRequestStatusLabel}}</text>
        </view>
        <view class="sub">
          <text wx:if="{{item.leaveApplicantStudentName}}">代提交：{{item.leaveApplicantStudentName}}</text>
        </view>
        <view class="sub">
          <text>{{item.displayTime}}</text>
        </view>
        <image
          wx:if="{{item.leaveRequestImageFileId}}"
          class="leave-img"
          src="{{item.leaveRequestImageFileId}}"
          mode="aspectFill"
          bindtap="previewImg"
          data-src="{{item.leaveRequestImageFileId}}"
        />
        <view class="score-btn-group">
          <button
            class="score-btn {{!isCurrentLessonSelected ? 'score-btn--disabled' : ''}}"
            size="mini"
            bindtap="onTapApproveLeaveRequest"
            data-request-id="{{item._id}}"
            data-student-id="{{item.studentId}}"
            data-student-name="{{item.studentName}}"
            data-can-operate="{{isCurrentLessonSelected}}"
            disabled="{{!isCurrentLessonSelected}}"
          >
            确认申请
          </button>
        </view>
      </view>
    </view>

    <view class="card" wx:for="{{list}}" wx:key="studentId" wx:for-item="item" wx:for-index="index" id="item-{{index}}">
      <view class="info">
        <text class="name">学生姓名：{{item.name}}</text>
      </view>

      <view class="sub">
        <text>学号：{{item.studentId || '-'}}</text>
      </view>

      <view class="sub">
        <text>状态：{{item.statusLabel || (item.status === 'signed' ? '已签到' : '未签到')}}</text>
      </view>

      <view class="sub" wx:if="{{item.hasPendingLeaveRequest && item.status !== 'leave_agree'}}">
        <text>请假申请：待处理{{item.pendingLeaveApplicantName ? '（代提交：' + item.pendingLeaveApplicantName + '）' : ''}}</text>
      </view>

      <view class="btn-row">
        <button
          class="btn {{item.canOperateAttendanceStatus && item.status === 'leave_agree' ? 'on' : ''}} {{!item.canOperateAttendanceStatus ? 'btn--disabled' : ''}}"
          size="mini"
          bindtap="onTapSetAttendanceStatus"
          data-status="leave_agree"
          data-current-status="{{item.status}}"
          data-student-id="{{item.studentId}}"
          data-student-name="{{item.name}}"
          data-can-operate="{{item.canOperateAttendanceStatus}}"
          disabled="{{!item.canOperateAttendanceStatus}}"
        >
          设为请假
        </button>
        <button
          class="btn {{item.canOperateAttendanceStatus && item.status === 'absent' ? 'on' : ''}} {{!item.canOperateAttendanceStatus ? 'btn--disabled' : ''}}"
          size="mini"
          bindtap="onTapSetAttendanceStatus"
          data-status="absent"
          data-current-status="{{item.status}}"
          data-student-id="{{item.studentId}}"
          data-student-name="{{item.name}}"
          data-can-operate="{{item.canOperateAttendanceStatus}}"
          disabled="{{!item.canOperateAttendanceStatus}}"
        >
          设为旷课
        </button>
      </view>

      <view class="sub" wx:if="{{item.lessonScoreText}}">
        <text>单次课最终分：{{item.lessonScoreText}}</text>
      </view>

      <view class="sub" wx:if="{{item.lessonScoreBreakdownText}}">
        <text>评分项：{{item.lessonScoreBreakdownText}}</text>
      </view>

      <view class="sub" wx:if="{{item.answerScoreText}}">
        <text>随机点名：{{item.answerScoreText}}（均分 {{item.answerScoreAvgText}}）</text>
      </view>

      <view class="sub" wx:if="{{item.questionScoreText}}">
        <text>主动提问：{{item.questionScoreText}}（均分 {{item.questionScoreAvgText}}）</text>
      </view>

      <view class="sub" wx:if="{{item.testScoreText}}">
        <text>随堂测试：{{item.testScoreText}}（均分 {{item.testScoreAvgText}}）</text>
      </view>
    </view>

    <view wx:if="{{list.length === 0}}" class="empty">暂无学生</view>
  </view>
</view>
