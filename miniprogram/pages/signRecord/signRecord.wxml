
<view class="page">
  <view class="stats-fixed">
    <view wx:if="{{currentStats}}" class="attendance-summary">
      <view class="attendance-summary-top">
        <view>
          <text class="attendance-summary-title">
            出勤：{{currentStats.signedCount}} / {{currentStats.rosterCount}}
          </text>
          <text class="attendance-summary-sub">
            未到：{{currentStats.unsignedCount}}
          </text>
        </view>
        <view class="export-btn-group">
          <button class="export-btn {{statsExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" bindtap="onTapExportLessonStats">导出全部课次统计</button>
          <button class="export-btn export-btn-secondary {{detailExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" bindtap="onTapExportLessonDetail">导出本次课明细</button>
        </view>
      </view>
    </view>

    <view class="interaction-card">
      <view class="interaction-title">课堂互动</view>
      <view class="interaction-current">
        <text>当前轮次：第{{currentRound}}轮</text>
      </view>
      <button class="export-btn" size="mini" bindtap="onTapRandomRollcall">随机点名</button>
      <view class="interaction-current">
        <text wx:if="{{currentCalledStudent}}">
          当前点名：{{currentCalledStudent.name}}（{{currentCalledStudent.studentId || '-'}}）
        </text>
        <text wx:else>当前未点名</text>
      </view>
      <view wx:if="{{currentCalledStudent}}" class="score-btn-group">
        <button
          wx:for="{{interactionScoreOptions}}"
          wx:key="*this"
          class="score-btn"
          size="mini"
          bindtap="onTapScoreAnswer"
          data-score="{{item}}"
        >
          {{item}}分
        </button>
      </view>
    </view>

    <view class="lesson-section">
      <view class="lesson-header">
        <text class="lesson-title">历史课次</text>
      </view>

      <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll" scroll-x="true" show-scrollbar="false">
        <view class="lesson-list">
          <view
            wx:for="{{lessons}}"
            wx:key="_id"
            class="lesson-item {{selectedLessonId === item._id ? 'active' : ''}}"
            bindtap="onSelectLesson"
            data-lesson-id="{{item._id}}"
          >
            <text class="lesson-item-title">课次 {{index + 1}}</text>
            <text class="lesson-item-id">{{item._id}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:else class="lesson-empty">暂无历史课次</view>
    </view>
  </view>

  <view class="list-container">
    <view class="card" wx:for="{{list}}" wx:key="studentId" wx:for-item="item" wx:for-index="index" id="item-{{index}}">
      <view class="info">
        <text class="name">学生姓名：{{item.name}}</text>
      </view>

      <view class="sub">
        <text>学号：{{item.studentId || '-'}}</text>
      </view>

      <view class="sub">
        <text>状态：{{item.status === 'signed' ? '已签到' : '未签到'}}</text>
      </view>

      <view wx:if="{{item.status === 'signed'}}" class="question-btn-row">
        <button class="question-btn" size="mini" bindtap="onTapAddStudentQuestion" data-student-id="{{item.studentId}}" data-student-name="{{item.name}}" data-score="1">主动提问 +1</button>
        <button class="question-btn" size="mini" bindtap="onTapAddStudentQuestion" data-student-id="{{item.studentId}}" data-student-name="{{item.name}}" data-score="2">主动提问 +2</button>
        <button class="question-btn" size="mini" bindtap="onTapAddStudentQuestion" data-student-id="{{item.studentId}}" data-student-name="{{item.name}}" data-score="3">主动提问 +3</button>
      </view>
    </view>

    <view wx:if="{{list.length === 0}}" class="empty">暂无学生</view>

    <view class="event-list">
      <view class="lesson-header">
        <text class="lesson-title">本节互动记录</text>
      </view>

      <view wx:if="{{lessonEventsLoading}}" class="lesson-empty">互动记录加载中</view>

      <view wx:elif="{{lessonEvents.length > 0}}">
        <view class="event-item" wx:for="{{lessonEvents}}" wx:key="_id">
          <view class="info">
            <text class="name">{{item.studentName || '未命名学生'}}</text>
            <text class="event-score" wx:if="{{item.score}}">+{{item.score}}</text>
          </view>
          <view class="sub">
            <text class="event-type">{{item.displayType}}</text>
          </view>
          <view class="sub">
            <text>{{item.displayTime}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="lesson-empty">本节暂无互动记录</view>
    </view>
  </view>
</view>
