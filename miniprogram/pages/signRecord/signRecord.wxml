<view class="sign-record-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section sign-record-hero">
    <view class="ui-card-head ui-page-head">
      <view class="hero-main ui-card-head ui-page-head-main">
        <view class="ui-eyebrow">教师业务页</view>
        <view class="ui-title-lg">签到记录</view>
        <view class="ui-text-body">用于查看课次切换、请假审批和学生签到明细，保持数据页层级清晰。</view>
      </view>
      <view class="hero-badge ui-tag ui-tag--active ui-page-head-badge">记录页</view>
    </view>

    <view wx:if="{{currentStats}}" class="hero-stats ui-stat-grid">
      <view class="hero-stat-card ui-stat-card">
        <view class="hero-stat-label ui-stat-label">到课情况</view>
        <view class="hero-stat-value ui-stat-value">出勤 {{currentStats.signedCount}} / {{currentStats.rosterCount}}</view>
      </view>
      <view class="hero-stat-card ui-stat-card">
        <view class="hero-stat-label ui-stat-label">未到人数</view>
        <view class="hero-stat-value ui-stat-value">{{currentStats.unsignedCount}}</view>
      </view>
    </view>
    <view wx:else class="ui-text-body">当前页用于查看签到状态、处理请假申请和导出课堂记录。</view>

    <view class="ui-record-actions export-actions">
      <button class="ui-btn-secondary export-btn {{statsExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" hover-class="ui-btn-active" bindtap="onTapExportLessonStats">导出全部课次统计</button>
      <button class="ui-btn-ghost export-btn {{detailExportDisabled ? 'export-btn--disabled' : ''}}" size="mini" hover-class="ui-btn-active" bindtap="onTapExportLessonDetail">导出本次课明细</button>
    </view>
  </view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">签到记录加载中</view>
    <view class="ui-state-desc">正在同步花名册、历史课次与签到记录。</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">签到记录读取失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryPageLoad">重新加载</button>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card lesson-switch-card">
    <view class="ui-card-head">
      <view class="ui-title-md">历史课次</view>
      <view class="ui-text-helper">切换课次后，下方会同步刷新请假申请与签到记录。</view>
    </view>

    <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll ui-scroll-x" scroll-x="true" show-scrollbar="false">
      <view class="ui-chip-list">
        <view
          wx:for="{{lessons}}"
          wx:key="_id"
          class="ui-chip-card {{selectedLessonId === item._id ? 'ui-chip-card--active' : ''}}"
          bindtap="onSelectLesson"
          hover-class="ui-btn-active"
          data-lesson-id="{{item._id}}"
        >
          <text class="ui-chip-title">课次 {{lessons.length - index}}</text>
          <text class="ui-chip-meta">{{item._id}}</text>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无历史课次</view>
      <view class="ui-empty-desc">开始上课后，这里会显示可切换的课次记录。</view>
    </view>
  </view>

  <view wx:if="{{pendingLeaveRequests.length > 0}}" class="ui-card ui-section ui-panel-card ui-panel-card--warning pending-card">
    <view class="ui-card-head">
      <view class="ui-title-md">待处理请假申请</view>
      <view class="ui-text-helper">仅当前选中的进行中课次允许处理请假申请。</view>
    </view>

    <view class="ui-record-list">
      <view class="ui-record-card ui-record-card--warning pending-record-card" wx:for="{{pendingLeaveRequests}}" wx:key="_id">
        <view class="ui-record-head">
          <view class="ui-card-head">
            <view class="ui-title-md">{{item.studentName}}</view>
            <view class="ui-text-helper">{{item.displayTime}}</view>
          </view>
          <view class="ui-tag ui-tag--pending">{{item.leaveRequestStatusLabel}}</view>
        </view>

        <view class="ui-info-list">
          <view class="ui-info-item">
            <view class="ui-info-label">处理态</view>
            <view class="ui-info-value">{{item.leaveRequestStatusLabel}}</view>
          </view>
          <view wx:if="{{item.leaveApplicantStudentName}}" class="ui-info-item">
            <view class="ui-info-label">代提交</view>
            <view class="ui-info-value">{{item.leaveApplicantStudentName}}</view>
          </view>
        </view>

        <image
          wx:if="{{item.leaveRequestImageFileId}}"
          class="leave-img"
          src="{{item.leaveRequestImageFileId}}"
          mode="aspectFill"
          bindtap="previewImg"
          data-src="{{item.leaveRequestImageFileId}}"
        />

        <view class="ui-record-actions">
          <button
            class="ui-btn-pill ui-btn-pill--warning leave-action-btn {{!isCurrentLessonSelected ? 'ui-btn-pill--disabled leave-action-btn--disabled' : ''}}"
            size="mini"
            bindtap="onTapApproveLeaveRequest"
            hover-class="ui-btn-active"
            data-request-id="{{item._id}}"
            data-student-id="{{item.studentId}}"
            data-student-name="{{item.studentName}}"
            data-can-operate="{{isCurrentLessonSelected}}"
            disabled="{{!isCurrentLessonSelected}}"
          >
            确认申请
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card student-list-card">
    <view class="ui-card-head">
      <view class="ui-title-md">学生签到状态</view>
      <view class="ui-text-helper">支持查看状态、手动设为请假或旷课，并展示本课评分结果。</view>
    </view>

    <view wx:if="{{list.length > 0}}" class="ui-record-list">
      <view class="ui-record-card ui-record-card--muted student-record-card" wx:for="{{list}}" wx:key="studentId" wx:for-item="item" wx:for-index="index" id="item-{{index}}">
        <view class="ui-record-head">
          <view class="ui-card-head">
            <view class="ui-title-md">{{item.name}}</view>
            <view class="ui-text-helper">学号：{{item.studentId || '-'}}</view>
          </view>
          <view class="ui-tag ui-tag--{{item.status || 'unsigned'}}">{{item.statusLabel || (item.status === 'signed' ? '已签到' : '未签到')}}</view>
        </view>

        <view wx:if="{{item.hasPendingLeaveRequest && item.status !== 'leave_agree'}}" class="ui-text-muted">请假申请：待处理{{item.pendingLeaveApplicantName ? '（代提交：' + item.pendingLeaveApplicantName + '）' : ''}}</view>

        <view class="ui-record-actions">
          <button
            class="ui-btn-pill attendance-btn attendance-btn--leave {{item.canOperateAttendanceStatus && item.status === 'leave_agree' ? 'ui-btn-pill--selected attendance-btn--active' : ''}} {{!item.canOperateAttendanceStatus ? 'ui-btn-pill--disabled attendance-btn--disabled' : ''}}"
            size="mini"
            bindtap="onTapSetAttendanceStatus"
            hover-class="ui-btn-active"
            data-status="leave_agree"
            data-current-status="{{item.status}}"
            data-student-id="{{item.studentId}}"
            data-student-name="{{item.name}}"
            data-can-operate="{{item.canOperateAttendanceStatus}}"
            disabled="{{!item.canOperateAttendanceStatus}}"
          >
            设为请假
          </button>
          <button
            class="ui-btn-pill attendance-btn attendance-btn--absent {{item.canOperateAttendanceStatus && item.status === 'absent' ? 'ui-btn-pill--active-danger attendance-btn--active-danger' : ''}} {{!item.canOperateAttendanceStatus ? 'ui-btn-pill--disabled attendance-btn--disabled' : ''}}"
            size="mini"
            bindtap="onTapSetAttendanceStatus"
            hover-class="ui-btn-active"
            data-status="absent"
            data-current-status="{{item.status}}"
            data-student-id="{{item.studentId}}"
            data-student-name="{{item.name}}"
            data-can-operate="{{item.canOperateAttendanceStatus}}"
            disabled="{{!item.canOperateAttendanceStatus}}"
          >
            设为旷课
          </button>
        </view>

        <view wx:if="{{item.lessonScoreText || item.lessonScoreBreakdownText || item.answerScoreText || item.questionScoreText || item.testScoreText}}" class="ui-info-list">
          <view wx:if="{{item.lessonScoreText}}" class="ui-info-item">
            <view class="ui-info-label">单次课最终分</view>
            <view class="ui-info-value">{{item.lessonScoreText}}</view>
          </view>
          <view wx:if="{{item.lessonScoreBreakdownText}}" class="ui-info-item">
            <view class="ui-info-label">评分项</view>
            <view class="ui-info-value">{{item.lessonScoreBreakdownText}}</view>
          </view>
          <view wx:if="{{item.answerScoreText}}" class="ui-info-item">
            <view class="ui-info-label">随机点名</view>
            <view class="ui-info-value">{{item.answerScoreText}}（均分 {{item.answerScoreAvgText}}）</view>
          </view>
          <view wx:if="{{item.questionScoreText}}" class="ui-info-item">
            <view class="ui-info-label">主动提问</view>
            <view class="ui-info-value">{{item.questionScoreText}}（均分 {{item.questionScoreAvgText}}）</view>
          </view>
          <view wx:if="{{item.testScoreText}}" class="ui-info-item">
            <view class="ui-info-label">随堂测试</view>
            <view class="ui-info-value">{{item.testScoreText}}（均分 {{item.testScoreAvgText}}）</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无学生</view>
      <view class="ui-empty-desc">当前班级还没有可展示的学生名单。</view>
    </view>
  </view>
</view>
