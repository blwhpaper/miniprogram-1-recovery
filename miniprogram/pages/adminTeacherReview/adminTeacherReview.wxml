<view class="admin-review-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section hero-card">
    <view class="ui-card-head ui-page-head">
      <view class="hero-head-main ui-card-head ui-page-head-main">
        <view class="ui-title-lg">管理员审核</view>
      </view>
      <view class="hero-status ui-tag ui-tag--{{pageState === 'ready' ? 'active' : pageState === 'loading' ? 'pending' : pageState === 'unauthorized' ? 'danger' : 'inactive'}} ui-page-head-badge">{{stateTitle}}</view>
    </view>
  </view>

  <view class="ui-card state-card ui-panel-card state-{{pageState}} ui-section">
    <view class="ui-card-head">
      <view class="ui-title-md">{{stateTitle}}</view>
      <view class="ui-text-body">{{stateDescription}}</view>
    </view>
    <view class="ui-card ui-card--subtle ui-section access-panel">
      <view class="ui-form-item">
        <view class="ui-form-label">管理员审核口令</view>
        <input
          class="ui-input"
          placeholder="请输入审核口令"
          value="{{adminReviewKey}}"
          bindinput="inputAdminReviewKey"
        />
      </view>
      <view class="ui-button-group ui-button-group--compact">
        <button type="primary" bindtap="loadApplications" loading="{{loading}}">
          读取申请
        </button>
        <button class="ui-btn-ghost" bindtap="clearAdminReviewSession">
          退出
        </button>
      </view>
    </view>
  </view>

  <view class="ui-card ui-notice-card ui-section reset-card">
    <view class="ui-card-head">
      <view class="ui-title-md">重置教师态</view>
    </view>
    <view class="ui-card ui-card--subtle ui-section reset-panel">
      <view class="ui-form-item">
        <view class="ui-form-label">目标账号 openid</view>
        <input
          class="ui-input"
          placeholder="请输入 openid"
          value="{{resetApplicantOpenId}}"
          bindinput="inputResetApplicantOpenId"
        />
      </view>
      <view class="ui-button-group">
        <button class="ui-btn-danger" bindtap="resetTeacherTestState" loading="{{resettingTeacherState}}">
          重置教师态
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{pageState === 'ready'}}" class="list-wrap">
    <view class="ui-card ui-card--subtle ui-section list-summary-card">
      <view class="ui-card-head">
        <view class="ui-title-md">待审核</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">数量</view>
          <view class="ui-info-value">{{applications.length}}</view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">真源</view>
          <view class="ui-info-value">{{teacherSourceDegraded ? '异常' : '正常'}}</view>
        </view>
      </view>
      <view wx:if="{{teacherSourceDegraded}}" class="ui-text-muted warning-text">真源异常。{{teacherSourceMessage}}</view>
    </view>

    <view class="ui-record-list review-list">
      <view wx:for="{{applications}}" wx:key="applicantOpenId" class="ui-record-card ui-section review-item">
        <view class="row-header">
          <view class="row-head-main ui-card-head">
            <view class="ui-title-md">{{item.applicantName}}</view>
            <view class="ui-text-helper">{{item.applicantOpenId}}</view>
          </view>
          <view class="ui-tag ui-tag--{{item.status || 'inactive'}}">{{item.applicationStatusText}}</view>
        </view>
        <view class="ui-divider"></view>
        <view class="review-meta ui-info-list">
          <view class="ui-info-item">
            <view class="ui-info-label">联系方式</view>
            <view class="ui-info-value">{{item.contactInfo}}</view>
          </view>
          <view class="ui-info-item">
            <view class="ui-info-label">备注</view>
            <view class="ui-info-value">{{item.remark || '-'}}</view>
          </view>
          <view class="ui-info-item">
            <view class="ui-info-label">提交时间</view>
            <view class="ui-info-value">{{item.createdAtText}}</view>
          </view>
          <view class="ui-info-item">
            <view class="ui-info-label">更新时间</view>
            <view class="ui-info-value">{{item.updatedAtText}}</view>
          </view>
          <view class="ui-info-item">
            <view class="ui-info-label">真源状态</view>
            <view class="ui-info-value">
              <text class="row-inline-tag ui-tag ui-tag--{{item.teacherSourceStatus || 'inactive'}}">{{item.teacherSourceStatusText}}</text>
            </view>
          </view>
          <view wx:if="{{item.teacherId}}" class="ui-info-item">
            <view class="ui-info-label">教师 ID</view>
            <view class="ui-info-value">{{item.teacherId}}</view>
          </view>
        </view>
        <view wx:if="{{item.teacherSourceWarningText}}" class="ui-text-body warning-text">{{item.teacherSourceWarningText}}</view>

        <view wx:if="{{item.status === 'pending'}}" class="ui-record-actions action-row">
          <button
            type="primary"
            data-openid="{{item.applicantOpenId}}"
            data-status="approved"
            bindtap="reviewApplication"
            loading="{{reviewingOpenId === item.applicantOpenId}}"
          >
            通过
          </button>
          <button
            class="ui-btn-ghost"
            data-openid="{{item.applicantOpenId}}"
            data-status="rejected"
            bindtap="reviewApplication"
            loading="{{reviewingOpenId === item.applicantOpenId}}"
          >
            驳回
          </button>
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{pageState === 'empty'}}" class="ui-card ui-empty-state ui-panel-card--empty empty-card">
    <view class="ui-empty-title">暂无申请</view>
    <view class="ui-empty-desc">{{emptyText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" bindtap="loadApplications">重试</button>
    </view>
  </view>
</view>
