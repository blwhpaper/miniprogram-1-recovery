.admin-review-page {
  align-items: stretch;
}

.hero-card {
  gap: var(--ui-space-4);
}

.state-card {
  box-shadow: var(--ui-shadow-card);
}

.state-loading {
  background: linear-gradient(135deg, var(--ui-color-primary-soft) 0%, #ffffff 100%);
  border-color: var(--ui-color-primary-border);
}

.state-unauthorized {
  background: linear-gradient(135deg, var(--ui-color-danger-soft) 0%, #ffffff 100%);
  border-color: var(--ui-color-danger-border);
}

.state-passwordRequired,
.state-empty {
  background: linear-gradient(135deg, var(--ui-color-warning-soft) 0%, #ffffff 100%);
  border-color: var(--ui-color-warning-border);
}

.state-ready {
  background: linear-gradient(135deg, var(--ui-color-success-soft) 0%, #ffffff 100%);
  border-color: var(--ui-color-success-border);
}

.access-panel,
.reset-panel,
.list-summary-card {
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}

.row-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
}

.row-head-main {
  flex: 1;
  min-width: 0;
}

.review-item {
  border: 1rpx solid rgba(37, 99, 235, 0.08);
  gap: var(--ui-space-4);
}

.action-row {
  margin-top: 4rpx;
}

.row-inline-tag {
  margin-left: 0;
  vertical-align: middle;
}

.warning-text {
  color: #b45309;
}

.review-list {
  gap: var(--ui-space-4);
}

.reset-card {
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}
