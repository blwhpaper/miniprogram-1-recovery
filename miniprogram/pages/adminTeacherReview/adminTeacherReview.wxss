.container {
  align-items: stretch;
}

.state-card {
  border: 1rpx solid #e5e7eb;
}

.state-loading {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.state-unauthorized {
  background: #fef2f2;
  border-color: #fecaca;
}

.state-passwordRequired,
.state-empty {
  background: #fffbeb;
  border-color: #fde68a;
}

.state-ready {
  background: #ecfdf5;
  border-color: #a7f3d0;
}

.summary,
.row-text { margin-top: 0; }

.field-label {
  margin-top: 0;
}

.row-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
}

.row-head-main {
  flex: 1;
  min-width: 0;
}

.review-item {
  gap: 20rpx;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 4rpx;
}

.action-row button {
  flex: 1 1 220rpx;
  min-width: 0;
}

.row-inline-tag {
  margin-left: 0;
  vertical-align: middle;
}

.warning-text {
  color: #b45309;
}

.empty-card {
  text-align: center;
}
