.container {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f6f6;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
}

.summary,
.row-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4b5563;
}

.field-label {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #111827;
}

.field-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid #d1d5db;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.load-btn {
  margin-top: 24rpx;
  border-radius: 16rpx;
}

.row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.reject-btn {
  background: #f3f4f6;
  color: #374151;
}

.empty-card {
  text-align: center;
}
