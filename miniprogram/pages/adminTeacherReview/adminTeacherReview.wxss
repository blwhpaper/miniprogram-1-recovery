.container {
  align-items: stretch;
}

.state-card {
  border: 1rpx solid #e5e7eb;
}

.state-loading {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.state-unauthorized {
  background: #fef2f2;
  border-color: #fecaca;
}

.state-passwordRequired,
.state-empty {
  background: #fffbeb;
  border-color: #fde68a;
}

.state-ready {
  background: #ecfdf5;
  border-color: #a7f3d0;
}

.summary,
.row-text { margin-top: 0; }

.field-label {
  margin-top: 0;
}

.load-btn {
  margin-top: 0;
}

.reset-btn {
  margin-top: 0;
}

.row-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.row-inline-tag {
  margin-left: 12rpx;
  vertical-align: middle;
}

.empty-card {
  text-align: center;
}
