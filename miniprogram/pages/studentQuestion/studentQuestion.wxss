@import "../../shared/genieLamp/genieLamp.wxss";

.question-page {
  align-items: stretch;
  padding-top: 0;
}

.question-card {
  gap: var(--ui-space-4);
  margin-top: 0;
}

.status {
  margin-top: 0;
}

.question-hero {
  margin-bottom: 4rpx;
}

.lamp-stage {
  padding: 0 0 4rpx;
}

.lamp-stage__crest {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  background: linear-gradient(180deg, #ffffff 0%, var(--ui-color-primary-soft) 100%);
}

.lamp-stage__symbol-shell {
  width: 456rpx;
  height: 356rpx;
  margin-top: -12rpx;
}

.lamp-stage__symbol {
  width: 456rpx;
  height: 356rpx;
}

.lamp-stage__title {
  font-size: var(--ui-font-lg);
  font-weight: 600;
  color: var(--ui-color-text);
}

.lamp-stage__desc {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.question-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  text-align: center;
}

.question-state__title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
}

.question-state__desc {
  font-size: var(--ui-font-sm);
  line-height: 1.8;
  color: var(--ui-color-text-muted);
}

.question-status {
  margin-top: 0;
  text-align: center;
}

.info-block {
  margin-top: 0;
}

.tip {
  margin-top: 0;
  text-align: center;
}

.submit-btn {
  margin: 0;
  border-radius: 999rpx !important;
  font-size: 32rpx;
}

.question-hero .status {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.18);
}

.question-hero .ui-feedback--success {
  background: rgba(236, 253, 245, 0.18);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.22);
}

.question-hero .ui-feedback--disabled,
.question-hero .ui-feedback--warning {
  background: rgba(15, 23, 42, 0.16);
  color: rgba(255, 255, 255, 0.9);
  border-color: rgba(255, 255, 255, 0.16);
}
