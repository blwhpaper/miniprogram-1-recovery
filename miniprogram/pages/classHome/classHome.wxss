.class-home-page {
  align-items: stretch;
}

.hero-info-list {
  margin-top: 4rpx;
}

.hero-note {
  margin-top: 0;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-grid button {
  flex: 1 1 280rpx;
}

.action-grid-btn--danger {
  flex-basis: 100%;
}

.qr-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 12rpx;
}

.qr-image {
  width: 440rpx;
  height: 440rpx;
  max-width: 100%;
  max-height: 440rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: var(--ui-color-card-bg);
  box-shadow: var(--ui-shadow-card);
  box-sizing: border-box;
}

.qr-empty {
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}
