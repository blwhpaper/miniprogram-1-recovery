.class-home-page {
  align-items: stretch;
}

.class-home-head {
  flex: 1;
}

.qr-wrap {
  display: flex;
  justify-content: center;
  padding: 12rpx 0;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.qr-empty {
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}
