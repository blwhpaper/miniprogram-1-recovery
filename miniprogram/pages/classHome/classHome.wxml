<view class="class-home-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section class-home-hero">
    <view class="ui-card-head ui-page-head">
      <view class="ui-card-head class-home-head ui-page-head-main">
        <view class="ui-title-lg">当前课堂</view>
      </view>
      <view wx:if="{{showEndLessonButton}}" class="ui-tag ui-tag--active">进行中</view>
      <view wx:else class="ui-tag ui-tag--inactive">未开始</view>
    </view>
    <view class="ui-info-list hero-info-list">
      <view class="ui-info-item">
        <view class="ui-info-label">班级</view>
        <view class="ui-info-value">{{classId || '-'}}</view>
      </view>
      <view class="ui-info-item">
        <view class="ui-info-label">课次</view>
        <view class="ui-info-value">{{lessonId || '-'}}</view>
      </view>
    </view>
    <view class="hero-note ui-text-muted">{{currentLessonStatusText}}</view>
    <button bindtap="createSignCode" hover-class="ui-btn-active" type="primary">开始签到</button>
  </view>

  <view class="ui-card ui-section ui-panel-card qr-card">
    <view class="ui-card-head">
      <view class="ui-title-md">签到二维码</view>
    </view>

    <view wx:if="{{pageLoading && !qrcode}}" class="ui-state-block ui-loading-state qr-empty">
      <view class="ui-state-title">加载中</view>
    </view>

    <view wx:elif="{{pageErrorText && !qrcode}}" class="ui-state-block ui-error-state qr-empty">
      <view class="ui-state-title">加载失败</view>
      <view class="ui-state-desc">{{pageErrorText}}</view>
      <view class="ui-state-actions">
        <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryRestoreCurrentLesson">重试</button>
      </view>
    </view>

    <view wx:elif="{{qrcode}}" class="qr-wrap">
      <image
        class="qr-image"
        src="{{qrcode}}"
        mode="aspectFit"
      ></image>
    </view>

    <view wx:else class="ui-empty-state qr-empty">
      <view class="ui-empty-title">暂无二维码</view>
    </view>
  </view>

  <view class="ui-card ui-notice-card ui-section ui-panel-card action-card">
    <view class="ui-card-head">
      <view class="ui-title-md">操作</view>
    </view>
    <view class="action-grid">
      <button class="ui-btn-secondary" bindtap="goToStudentList" hover-class="ui-btn-active">学生名单</button>
      <button class="ui-btn-secondary" bindtap="goToClassInteraction" hover-class="ui-btn-active">课堂互动</button>
      <button wx:if="{{showEndLessonButton}}" class="ui-btn-danger action-grid-btn--danger" bindtap="confirmEndCurrentLesson" hover-class="ui-btn-active">下课</button>
    </view>
  </view>
</view>
