.dispatch-page {
  padding-top: calc(var(--ui-space-7) + constant(safe-area-inset-top));
  padding-top: calc(var(--ui-space-7) + env(safe-area-inset-top));
  padding-bottom: calc(var(--ui-space-7) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--ui-space-7) + env(safe-area-inset-bottom));
}

.dispatch-card {
  max-width: 640rpx;
  width: 100%;
  padding: 68rpx 52rpx;
  text-align: center;
  box-sizing: border-box;
}

.dispatch-mark {
  letter-spacing: 2rpx;
}

.dispatch-desc {
  margin-top: 8rpx;
}

.dispatch-tip {
  margin-top: 4rpx;
}
