<view class="student-leave-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--primary ui-section hero-card">
    <view class="ui-card-head">
      <view class="ui-title-lg">请假申请</view>
      <view class="ui-text-body">{{pageHintText}}</view>
    </view>
  </view>

  <view wx:if="{{shouldGoRegister}}" class="ui-card ui-section ui-surface--warning register-card">
    <view class="ui-card-head">
      <view class="ui-title-md">先绑定</view>
    </view>
    <view class="ui-feedback ui-feedback--warning">{{registerTipText}}</view>
    <view class="ui-button-group">
      <button type="primary" bindtap="goRegister">去绑定</button>
    </view>
  </view>

  <block wx:else>
    <view class="ui-card ui-card--subtle ui-section status-card">
      <view class="ui-card-head">
        <view class="ui-title-md">当前状态</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">出勤状态</view>
          <view class="ui-info-value">{{attendanceStatusText}}</view>
        </view>
      </view>
      <view class="ui-feedback ui-feedback--{{attendanceStatus === 'leave_agree' ? 'success' : attendanceStatus === 'absent' ? 'danger' : attendanceStatus === 'leave_wait' ? 'warning' : !signSuccess ? 'danger' : 'info'}}">
        <text wx:if="{{attendanceStatus === 'leave_agree'}}">无需提交</text>
        <text wx:elif="{{attendanceStatus === 'absent'}}">不可提交</text>
        <text wx:elif="{{attendanceStatus === 'leave_wait'}}">待审批</text>
        <text wx:elif="{{!signSuccess}}">先签到</text>
        <text wx:else>可提交</text>
      </view>
    </view>

    <view class="ui-card ui-section ui-form-card leave-form-card">
      <view class="ui-card-head">
        <view class="ui-title-md">代提交</view>
      </view>

      <view class="ui-form-item">
        <view class="ui-form-label">请假人</view>
        <input
          class="ui-input"
          placeholder="请输入请假人姓名"
          value="{{leaveRequestTargetName}}"
          bindinput="onInputLeaveRequestTargetName"
        />
        <view class="ui-feedback ui-feedback--{{leaveRequestTargetStatus || 'idle'}}">
          {{leaveRequestTargetStatusText}}
        </view>
      </view>

      <view class="ui-form-item">
        <view class="ui-form-label">假条</view>
        <view class="ui-button-group ui-button-group--compact">
          <button class="ui-btn-secondary" bindtap="chooseLeaveRequestImage">上传假条</button>
        </view>
        <view class="ui-feedback ui-feedback--{{leaveRequestImageTempPath ? 'matched' : 'idle'}}">
          {{leaveRequestImageTempPath ? '已上传' : '未上传'}}
        </view>
        <image wx:if="{{leaveRequestImageTempPath}}" class="leave-img" src="{{leaveRequestImageTempPath}}" mode="aspectFill" />
      </view>

      <view class="ui-form-item">
        <view class="ui-form-label">提交</view>
        <view class="ui-card ui-card--subtle ui-section summary-card" wx:if="{{leaveRequestMatchedStudentName || leaveRequestImageTempPath}}">
          <view class="ui-info-list">
            <view class="ui-info-item">
              <view class="ui-info-label">提交对象</view>
              <view class="ui-info-value">{{leaveRequestMatchedStudentName || '-'}}</view>
            </view>
            <view class="ui-info-item">
              <view class="ui-info-label">假条材料</view>
              <view class="ui-info-value">{{leaveRequestImageTempPath ? '已上传' : '未上传'}}</view>
            </view>
          </view>
        </view>
        <view class="ui-button-group">
          <button type="primary" bindtap="submitLeaveRequest" disabled="{{!canSubmitLeaveRequest || leaveRequestSubmitting}}" loading="{{leaveRequestSubmitting}}">
            提交请假申请
          </button>
        </view>
        <view class="ui-feedback ui-feedback--{{leaveRequestSubmitting ? 'submitting' : canSubmitLeaveRequest ? 'matched' : 'idle'}}">
          {{leaveRequestSubmitting ? '提交中' : canSubmitLeaveRequest ? '可提交' : '信息不完整'}}
        </view>
      </view>
    </view>

    <view wx:if="{{leaveRequestLastSubmittedName}}" class="ui-card ui-notice-card ui-section result-card">
      <view class="ui-card-head">
        <view class="ui-title-md">{{leaveRequestLastSubmittedTitle || '最近记录'}}</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">提交对象</view>
          <view class="ui-info-value">{{leaveRequestLastSubmittedName}}</view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">当前记录</view>
          <view class="ui-info-value">{{leaveRequestLastSubmittedStatusText}}</view>
        </view>
        <view wx:if="{{leaveRequestLastSubmittedTimeText}}" class="ui-info-item">
          <view class="ui-info-label">提交时间</view>
          <view class="ui-info-value">{{leaveRequestLastSubmittedTimeText}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
