<view class="container ui-page ui-page--stack">
  <view class="hero-card ui-card ui-hero-card ui-hero-card--teacher ui-section">
    <view class="hero-head ui-page-head">
      <view class="hero-head-main ui-card-head ui-page-head-main">
        <view class="hero-kicker ui-eyebrow">课堂签到</view>
        <view class="hero-title ui-title-lg">{{teacherName}}</view>
      </view>
      <view class="hero-status ui-tag ui-tag--{{teacherApplyStatus || 'inactive'}} ui-page-head-badge">{{teacherStatusText}}</view>
    </view>
    <view class="hero-desc ui-text-body">{{teacherLeadText}}</view>
  </view>

    <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryLoadTeacherHomeState">重试</button>
    </view>
  </view>

  <block wx:else>
    <view wx:if="{{hasTeacherSession}}" class="panel ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="panel-title ui-title-md">教师工作区</view>
      </view>
      <view class="ui-button-group">
        <button type="primary" hover-class="ui-btn-active" bindtap="goToClassManager">班级管理</button>
        <button class="secondary-btn ui-btn-secondary" hover-class="ui-btn-active" bindtap="logoutTeacherSession">
          退出教师态
        </button>
      </view>
    </view>

    <view wx:else class="panel ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="panel-title ui-title-md">教师申请</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">当前状态</view>
          <view class="ui-info-value">
            <view class="ui-tag ui-tag--{{teacherApplyStatus || 'inactive'}}">{{teacherApplyStatusText}}</view>
          </view>
        </view>
      </view>
      <view class="panel-text ui-text-body">{{teacherApplySummaryText}}</view>
      <view class="ui-button-group">
        <button wx:if="{{canResumeTeacherSession}}" type="primary" hover-class="ui-btn-active" bindtap="resumeTeacherSession">
          恢复教师态
        </button>
        <button wx:if="{{canEnterTeacherWorkspace}}" type="primary" hover-class="ui-btn-active" bindtap="enterApprovedTeacherWorkspace">
          班级管理
        </button>
        <button wx:if="{{showTeacherApplyButton}}" type="primary" hover-class="ui-btn-active" bindtap="goToTeacherApply" disabled="{{teacherApplyButtonDisabled}}">
          {{teacherApplyButtonText}}
        </button>
      </view>
    </view>

    <view class="panel panel--muted ui-card ui-notice-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="panel-title ui-title-md">管理</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">教师标识</view>
          <view class="ui-info-value">
            <view class="ui-tag ui-tag--{{teacherId ? 'active' : 'inactive'}}">{{teacherId || "未开通"}}</view>
          </view>
        </view>
      </view>
      <button class="weak-entry-btn ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="goToAdminTeacherReview">
        管理员审核
      </button>
    </view>
  </block>
</view>
