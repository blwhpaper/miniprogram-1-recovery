.container {
  align-items: stretch;
}

.hero-kicker {
  margin-bottom: 12rpx;
}

.hero-status {
  margin-top: 16rpx;
  align-self: flex-start;
}

.hero-desc {
  margin-top: 16rpx;
}

.panel--muted {
