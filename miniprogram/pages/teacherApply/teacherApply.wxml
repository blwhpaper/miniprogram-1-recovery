<view class="container">
  <view class="card">
    <view class="title">老师注册申请</view>
    <view class="status">{{applicationStatusText}}</view>
    <view class="summary">{{applicationSummaryText}}</view>
  </view>

  <view class="card">
    <view class="field-label">姓名</view>
    <input
      class="field-input"
      placeholder="请输入姓名"
      value="{{applicantName}}"
      bindinput="inputApplicantName"
      disabled="{{submitDisabled}}"
    />

    <view class="field-label">联系方式</view>
    <input
      class="field-input"
      placeholder="请输入手机号或微信号"
      value="{{contactInfo}}"
      bindinput="inputContactInfo"
      disabled="{{submitDisabled}}"
    />

    <view class="field-label">备注（选填）</view>
    <textarea
      class="field-textarea"
      placeholder="可填写任教说明或补充信息"
      value="{{remark}}"
      bindinput="inputRemark"
      maxlength="100"
      disabled="{{submitDisabled}}"
    />

    <button
      class="submit-btn"
      type="primary"
      bindtap="submitTeacherApply"
      disabled="{{submitDisabled || hasTeacherSession}}"
    >
      {{submitDisabled ? "已提交，等待审核" : hasTeacherSession ? "当前已是教师" : "提交老师申请"}}
    </button>
  </view>
</view>
