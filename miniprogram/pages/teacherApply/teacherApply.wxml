<view class="teacher-apply-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section hero-card">
    <view class="ui-card-head ui-page-head">
      <view class="hero-head-main ui-card-head ui-page-head-main">
        <view class="ui-title-lg">教师申请</view>
      </view>
      <view class="hero-status ui-tag ui-tag--{{applicationStatus || 'inactive'}} ui-page-head-badge">{{applicationStatusText}}</view>
    </view>
    <view class="ui-text-muted">{{applicationSummaryText}}</view>
  </view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" bindtap="retryLoadApplicationState">重试</button>
    </view>
  </view>

  <block wx:else>
    <view class="ui-card ui-card--subtle ui-section ui-panel-card status-card">
      <view class="ui-card-head">
        <view class="ui-title-md">状态</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">申请状态</view>
          <view class="ui-info-value">
            <text class="inline-tag ui-tag ui-tag--{{applicationStatus || 'inactive'}}">{{applicationStatusText}}</text>
          </view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">提交</view>
          <view class="ui-info-value">{{submitDisabled ? "暂不可提交" : hasTeacherSession ? "已开通" : "可提交"}}</view>
        </view>
      </view>
      <view class="ui-text-muted">{{applicationSummaryText}}</view>
    </view>

    <view class="ui-card ui-notice-card ui-section ui-panel-card notice-card">
      <view class="ui-card-head">
        <view class="ui-title-md">说明</view>
      </view>
      <view class="ui-text-muted">提交后待审核</view>
    </view>

    <view class="ui-card ui-section ui-form-card ui-panel-card form-card">
      <view class="ui-card-head">
        <view class="ui-title-md">信息</view>
      </view>
      <view class="form-fields ui-section">
        <view class="ui-form-item">
          <view class="ui-form-label">姓名</view>
          <input
            class="ui-input"
            placeholder="请输入姓名"
            value="{{applicantName}}"
            bindinput="inputApplicantName"
            disabled="{{submitDisabled}}"
          />
        </view>

        <view class="ui-form-item">
          <view class="ui-form-label">联系方式</view>
          <input
            class="ui-input"
            placeholder="请输入手机号"
            value="{{contactInfo}}"
            bindinput="inputContactInfo"
            disabled="{{submitDisabled}}"
          />
        </view>

        <view class="ui-form-item">
          <view class="ui-form-label">备注（选填）</view>
          <textarea
            class="ui-textarea"
            placeholder="可填写任教说明或补充信息"
            value="{{remark}}"
            bindinput="inputRemark"
            maxlength="100"
            disabled="{{submitDisabled}}"
          />
        </view>
      </view>

      <view class="ui-button-group">
        <button
          type="primary"
          bindtap="submitTeacherApply"
          disabled="{{submitDisabled || hasTeacherSession}}"
        >
          {{submitDisabled ? "已提交" : hasTeacherSession ? "已开通" : "提交申请"}}
        </button>
      </view>
    </view>
  </block>
</view>
