.class-manager-page {
  align-items: stretch;
}

.hero-summary {
  margin-top: 4rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 24rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.class-entry-main {
  padding: 8rpx 0;
}

.class-entry-head {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 24rpx;
}

.class-entry-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.class-entry-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.delete-btn {
  width: auto !important;
  min-width: 120rpx !important;
  min-height: 64rpx !important;
  padding: 12rpx 24rpx !important;
  border-color: var(--ui-color-danger-border) !important;
  color: var(--ui-color-danger) !important;
  background: var(--ui-color-danger-soft) !important;
}
