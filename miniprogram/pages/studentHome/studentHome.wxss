.page {
  /* 页面顶部预留安全距离 */
  padding-top: calc(var(--ui-space-5) + constant(safe-area-inset-top));
  padding-top: calc(var(--ui-space-5) + env(safe-area-inset-top));
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--ui-space-3);
}

.title-wrap {
  flex: 1;
  min-width: 0;
}

.page-badge {
  flex-shrink: 0;
  align-self: flex-start;
}

.hero-block {
  margin-top: var(--ui-space-2);
}

.hero-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-status {
  transition: all 0.3s ease;
}

.hero-summary {
  margin-top: var(--ui-space-2);
}

.hero-entry-btn {
  margin-top: var(--ui-space-4);
  width: 100% !important;
}

.summary-tip {
  margin-top: var(--ui-space-2);
  padding: var(--ui-space-2) var(--ui-space-3);
  background: var(--ui-color-card-subtle);
  border-radius: var(--ui-radius-sm);
  font-style: italic;
}
