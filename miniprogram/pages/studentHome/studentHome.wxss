.page {
  padding-top: 40rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.page-badge {
  flex-shrink: 0;
}

.hero-block {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dbe7ff;
}

.hero-status {
  margin-top: 12rpx;
  font-size: 40rpx;
}

.hero-debug {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(17, 24, 39, 0.05);
  color: #374151;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

.hero-debug-secondary {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #4b5563;
}

.hero-entry-btn {
  margin-top: 24rpx;
}

.info-block,
.lesson-block,
.summary-block {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-block {
  margin-top: 28rpx;
}

.secondary-action {
  margin-top: 20rpx;
}
