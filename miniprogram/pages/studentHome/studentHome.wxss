.page {
  padding-top: 40rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
}

.title-wrap {
  flex: 1;
  min-width: 0;
}

.page-badge {
  flex-shrink: 0;
  align-self: flex-start;
}

.hero-block {
  margin-top: 8rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dbe7ff;
}

.hero-status {
  margin-top: 12rpx;
  font-size: 40rpx;
}

.hero-entry-btn {
  margin-top: 24rpx;
}

.info-block,
.lesson-block,
.summary-block,
.action-card {
  margin-top: 0;
}

.secondary-action {
  margin-top: 0;
}
