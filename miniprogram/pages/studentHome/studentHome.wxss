.page {
  padding-top: 0;
}

.student-home-hero {
  margin-bottom: 4rpx;
}

.student-home-kicker {
  color: rgba(255, 255, 255, 0.76);
}

.student-home-pill {
  align-self: flex-start;
}

.hero-block {
  margin-top: 0;
  box-shadow: none;
}

.hero-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-status {
  transition: all 0.3s ease;
}

.hero-summary {
  margin-top: var(--ui-space-2);
}

.hero-entry-btn {
  margin-top: var(--ui-space-4);
  width: 100% !important;
}

.action-card {
  margin-top: 0;
}

.action-tile {
  width: 100%;
  margin: 0;
  min-height: 156rpx;
  height: auto !important;
  padding: 24rpx !important;
  background: var(--ui-color-card-subtle) !important;
  border: 1rpx solid var(--ui-color-border) !important;
  box-shadow: none !important;
  align-items: flex-start !important;
}

.teacher-entry-tile {
  background: #ffffff !important;
}

.summary-tip {
  margin-top: var(--ui-space-2);
  padding: var(--ui-space-2) var(--ui-space-3);
  background: var(--ui-color-card-subtle);
  border-radius: var(--ui-radius-sm);
  font-style: italic;
}
