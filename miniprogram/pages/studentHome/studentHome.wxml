<view class="page">
  <view class="card">
    <view class="title-row">
      <view class="title">学生主页</view>
      <view class="page-badge">当前课入口</view>
    </view>

    <view class="hero-block">
      <view class="hero-label">{{pageLeadText}}</view>
      <view class="hero-status">{{statusText}}</view>
      <view class="hero-summary">{{summaryText}}</view>
      <button wx:if="{{showLessonEntryButton}}" class="hero-entry-btn" type="primary" bindtap="enterCurrentLesson">
        {{lessonEntryText}}
      </button>
    </view>

    <view wx:if="{{hasBoundStudentSession}}" class="info-block">
      <view>当前学生：{{name}}</view>
      <view>学号：{{studentId}}</view>
    </view>

    <view wx:if="{{hasBoundStudentSession && showLessonScoreSummary}}" class="summary-block">
      <view class="summary-title">本课汇总</view>
      <view>出勤状态：{{currentLessonAttendanceStatusText || '-'}}</view>
      <view>出勤分：{{currentLessonAttendanceScoreText || '-'}}</view>
      <view>课堂积分：{{currentLessonScoreText || '-'}}</view>
      <view wx:if="{{currentLessonScoreBreakdownText}}" class="summary-tip">
        积分构成：{{currentLessonScoreBreakdownText}}
      </view>
    </view>

    <view class="lesson-block">
      <view class="lesson-summary-title">当前课承接</view>
      <view class="tip">{{summaryText}}</view>
    </view>

    <view wx:if="{{showQuestionEntryButton}}" class="action-block secondary-action">
      <button bindtap="enterQuestionEntry">
        进入主动提问
      </button>
    </view>

    <view wx:if="{{hasBoundStudentSession && lessonId && lessonEntryMode !== 'leave_result'}}" class="action-block secondary-action">
      <button bindtap="enterLeaveRequestPage">
        进入请假申请
      </button>
    </view>
  </view>
</view>
