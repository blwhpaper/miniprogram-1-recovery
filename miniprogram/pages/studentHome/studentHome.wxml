<view class="page ui-page ui-page--stack">
  <view class="student-home-hero ui-hero-section">
    <view class="ui-hero-section__content">
      <view class="title-row ui-hero-section__head">
        <view class="title-wrap ui-card-head ui-page-head-main">
          <view class="student-home-kicker ui-hero-section__desc">学生主页</view>
          <view class="title ui-hero-section__title">当前课堂</view>
        </view>
        <view class="student-home-pill ui-hero-pill">学生</view>
      </view>

      <view class="hero-block ui-card ui-section ui-panel-card">
        <view class="hero-header">
          <view class="hero-label ui-eyebrow">{{pageLeadText}}</view>
          <view class="hero-status ui-title-hero">{{statusText}}</view>
        </view>
        <view class="hero-summary ui-text-body">{{summaryText}}</view>
        <button wx:if="{{showLessonEntryButton}}" class="hero-entry-btn" type="primary" hover-class="ui-btn-active" bindtap="enterCurrentLesson">
          {{lessonEntryText}}
        </button>
      </view>
    </view>
  </view>

    <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryLoadHomeState">重试</button>
    </view>
  </view>

  <block wx:else>
    <view wx:if="{{hasBoundStudentSession}}" class="info-block ui-card ui-card--subtle ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="ui-title-md">学生信息</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">当前学生</view>
          <view class="ui-info-value">{{name}}</view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">学号</view>
          <view class="ui-info-value">{{studentId}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasBoundStudentSession && showLessonScoreSummary}}" class="summary-block ui-card ui-card--subtle ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="summary-title ui-title-md">本课汇总</view>
      </view>
      <view class="ui-info-list">
        <view class="ui-info-item">
          <view class="ui-info-label">出勤状态</view>
          <view class="ui-info-value">{{currentLessonAttendanceStatusText || '-'}}</view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">出勤分</view>
          <view class="ui-info-value">{{currentLessonAttendanceScoreText || '-'}}</view>
        </view>
        <view class="ui-info-item">
          <view class="ui-info-label">课堂积分</view>
          <view class="ui-info-value">{{currentLessonScoreText || '-'}}</view>
        </view>
      </view>
      <view wx:if="{{currentLessonScoreBreakdownText}}" class="summary-tip ui-text-muted">
          {{currentLessonScoreBreakdownText}}
      </view>
    </view>

    <view class="lesson-block ui-card ui-notice-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="lesson-summary-title ui-title-md">说明</view>
      </view>
      <view class="tip ui-text-muted">{{summaryText}}</view>
    </view>

    <view wx:if="{{showQuestionEntryButton || (hasBoundStudentSession && lessonId && lessonEntryMode !== 'leave_result') || showTeacherHomeEntry}}" class="action-card ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="ui-title-md">操作</view>
      </view>
      <view class="ui-action-grid">
        <button wx:if="{{showQuestionEntryButton}}" class="action-tile ui-action-tile" hover-class="ui-btn-active" bindtap="enterQuestionEntry">
          <view class="ui-action-tile__title">主动提问</view>
          <view class="ui-action-tile__desc">单次发起提问请求</view>
        </button>

        <button wx:if="{{hasBoundStudentSession && lessonId && lessonEntryMode !== 'leave_result'}}" class="action-tile ui-action-tile" hover-class="ui-btn-active" bindtap="enterLeaveRequestPage">
          <view class="ui-action-tile__title">请假申请</view>
          <view class="ui-action-tile__desc">提交本课请假信息</view>
        </button>

        <button wx:if="{{showTeacherHomeEntry}}" class="action-tile ui-action-tile teacher-entry-tile" hover-class="ui-btn-active" bindtap="enterTeacherHome">
          <view class="ui-action-tile__title">教师入口</view>
          <view class="ui-action-tile__desc">切换到教师工作区</view>
        </button>
      </view>
    </view>

  </block>
</view>
