<view class="page">
  <view class="card">
    <view class="title">学生主页</view>
    <view class="subtitle">这里会保留你当前可继续进入的课堂入口。</view>
    <view class="status">当前状态：{{statusText}}</view>

    <view wx:if="{{hasBoundStudentSession}}" class="info-block">
      <view>当前学生：{{name}}</view>
      <view>学号：{{studentId}}</view>
    </view>

    <view class="lesson-block">
      <view class="tip">{{summaryText}}</view>
    </view>

    <view wx:if="{{showLessonEntryButton}}" class="action-block">
      <button type="primary" bindtap="enterCurrentLesson">
        {{lessonEntryText}}
      </button>
    </view>

    <view wx:if="{{showQuestionEntryButton}}" class="action-block secondary-action">
      <button bindtap="enterQuestionEntry">
        进入主动提问
      </button>
    </view>
  </view>
</view>
