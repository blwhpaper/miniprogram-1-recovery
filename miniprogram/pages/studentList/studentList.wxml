<view class="student-list-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section">
    <view class="ui-card-head">
      <view class="ui-title-lg">学生名单</view>
    </view>
    <view class="ui-info-list">
      <view class="ui-info-item">
        <view class="ui-info-label">当前班级人数</view>
        <view class="ui-info-value">{{studentCount}}</view>
      </view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card">
    <view class="ui-card-head">
      <view class="ui-title-md">操作</view>
    </view>
    <view class="ui-button-group">
      <button bindtap="uploadCSV" hover-class="ui-btn-active" class="upload-btn ui-btn-secondary">上传名单</button>
      <button bindtap="goSignRecord" hover-class="ui-btn-active" type="primary">签到记录</button>
      <button bindtap="goClassInteraction" hover-class="ui-btn-active" class="ui-btn-secondary">课堂互动</button>
    </view>
  </view>
</view>
