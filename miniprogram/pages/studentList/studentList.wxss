.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}
.upload-btn {
  background: #1677ff;
  color: white;
  margin-bottom: 20rpx;
}
.tip {
  color: #666;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.clear-btn {
  background: #ff4d4f;
  color: white;
  margin-bottom: 40rpx;
}
.list {
  background: white;
  border-radius: 15rpx;
  padding: 20rpx;
}
.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.item:last-child {
  border-bottom: none;
}
.info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.empty {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
}