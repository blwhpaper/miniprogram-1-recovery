.primary-action {
  margin: 0;
  min-height: 108rpx;
  font-size: 32rpx;
}

.primary-action--disabled {
  opacity: 1;
}

.score-panel {
  margin-top: 6rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff8ed;
  border: 1rpx solid #ffe0b3;
}

.score-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #9a6700;
}

.score-btn {
  margin: 0;
  flex: 1 1 180rpx;
  min-width: 180rpx;
  line-height: 1.6;
}

.rollcall-page {
  align-items: stretch;
}

.event-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #16a34a;
  align-self: flex-start;
}

.event-round {
  color: #2563eb;
}
