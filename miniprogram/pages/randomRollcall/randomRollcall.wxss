.rollcall-page {
  align-items: stretch;
  padding-top: 0;
}

.rollcall-hero {
  margin-bottom: 4rpx;
}

.rollcall-hero-status {
  margin-top: 0;
}

.focus-card,
.action-card,
.lesson-switch-card,
.history-card {
  margin-top: 0;
}

.rollcall-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ui-space-4);
}

.rollcall-stage__summary {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.rollcall-stage__action {
  position: relative;
  display: flex;
  justify-content: center;
  width: 100%;
}

.rollcall-trigger-shell {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rollcall-trigger {
  position: relative;
  width: 168rpx !important;
  height: 168rpx !important;
  min-height: 168rpx !important;
  padding: 0 !important;
  border: none !important;
  border-radius: 50% !important;
  background: transparent !important;
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transform: translateY(0) scale(1);
  transition: transform 0.16s ease, opacity 0.16s ease, filter 0.16s ease;
}

.rollcall-trigger::after {
  border: none !important;
}

.rollcall-trigger:active {
  transform: translateY(4rpx) scale(0.97);
}

.rollcall-trigger--disabled {
  opacity: 0.52;
  filter: saturate(0.82);
}

.rollcall-trigger__image {
  width: 168rpx;
  height: 168rpx;
  display: block;
}

.number-card-stage {
  position: relative;
  width: 100%;
  padding: 12rpx 0 20rpx;
  overflow: hidden;
}

.number-card-stage__glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 420rpx;
  height: 220rpx;
  margin-left: -210rpx;
  margin-top: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.16) 0%, rgba(37, 99, 235, 0.04) 54%, rgba(37, 99, 235, 0) 100%);
  filter: blur(16rpx);
  pointer-events: none;
}

.number-card-pair {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  min-height: 300rpx;
  z-index: 1;
}

.number-card-face {
  width: 184rpx;
  height: 184rpx;
  padding: 18rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef4ff 62%, #dbeafe 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  box-shadow: 0 18rpx 32rpx rgba(37, 99, 235, 0.12);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
  transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
}

.number-card-face__digit {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  line-height: 1;
  font-weight: 800;
  color: #1d4ed8;
  text-align: center;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 10rpx rgba(37, 99, 235, 0.12);
}

.number-card-face--left {
  transform: rotate(-6deg);
}

.number-card-face--right {
  transform: rotate(6deg);
}

.number-card-face--rolling {
  animation: dice-roll 0.72s ease-in-out;
  box-shadow: 0 18rpx 38rpx rgba(37, 99, 235, 0.18);
  filter: saturate(1.02);
}

.rollcall-result-card {
  width: 100%;
}

.rollcall-result {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.rollcall-result--pending {
  align-items: center;
  text-align: center;
}

.rollcall-result__math {
  font-size: var(--ui-font-lg);
  font-weight: 700;
  line-height: 1.5;
  color: var(--ui-color-text);
  text-align: center;
}

.rollcall-result__student {
  display: flex;
  align-items: center;
  gap: var(--ui-space-3);
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
}

.rollcall-result__avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--ui-color-primary-soft) 0%, #dbeafe 100%);
  color: var(--ui-color-primary);
  font-size: 36rpx;
  font-weight: 700;
  border: 1rpx solid var(--ui-color-primary-border);
}

.rollcall-result__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rollcall-result__name {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
}

.rollcall-result__meta,
.rollcall-result__summary {
  font-size: var(--ui-font-sm);
  line-height: 1.75;
  color: var(--ui-color-text-muted);
}

.rollcall-result__placeholder {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-primary);
}

.rollcall-result__hint {
  margin-top: 0;
  text-align: center;
}

.score-panel {
  margin-top: 6rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--ui-color-warning-soft);
  border: 1rpx solid var(--ui-color-warning-border);
}

.score-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #b45309;
}

.score-btn {
  margin: 0;
  flex: 1 1 180rpx;
  min-width: 180rpx;
  line-height: 1.6;
}

.history-record-card {
  gap: 10rpx;
}

.event-score {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ui-color-success);
  align-self: flex-start;
}

.event-round {
  color: var(--ui-color-primary);
}

.lesson-chip-current {
  margin-left: 10rpx;
  color: var(--ui-color-primary);
}

@keyframes dice-roll {
  0% {
    transform: translateY(0) rotate(-8deg) scale(1);
  }

  25% {
    transform: translateY(-10rpx) rotate(10deg) scale(1.03);
  }

  50% {
    transform: translateY(6rpx) rotate(-14deg) scale(0.98);
  }

  75% {
    transform: translateY(-4rpx) rotate(8deg) scale(1.01);
  }

  100% {
    transform: translateY(0) rotate(0deg) scale(1);
  }
}
