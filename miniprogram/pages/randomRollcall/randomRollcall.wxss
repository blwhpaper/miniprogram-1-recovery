.page {
  min-height: 100vh;
  background: #f7f8fc;
}

.stats-fixed {
  position: fixed; top:0; left:0; right:0; background:#f7f8fc; z-index:999;
  display:flex; flex-direction:column; padding:20rpx 20rpx 16rpx;
  border-bottom:1rpx solid #e8ebf2;
  box-sizing:border-box;
}
.attendance-summary {
  background:#f5f5f5;
  border-radius:16rpx;
  padding:20rpx;
  margin-bottom:20rpx;
}
.attendance-summary-top {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:16rpx;
}
.export-btn-group {
  display:flex;
  gap:12rpx;
}
.attendance-summary-title {
  display:block;
  font-size:30rpx;
  font-weight:600;
  color:#333;
}
.attendance-summary-sub {
  display:block;
  margin-top:8rpx;
  font-size:24rpx;
  color:#666;
}
.export-btn {
  margin:0;
  background:#2f77ff;
  color:#fff;
  border-radius:999rpx;
  line-height:1.6;
}
.export-btn-secondary {
  background:#5b6573;
}
.export-btn--disabled {
  opacity: 0.45;
  filter: grayscale(1);
}
.interaction-card {
  background:linear-gradient(180deg, #ffffff 0%, #f4f7ff 100%);
  border-radius:24rpx;
  padding:24rpx;
  margin-bottom:20rpx;
  box-shadow:0 12rpx 28rpx rgba(47, 119, 255, 0.08);
}
.interaction-card--pending {
  box-shadow:0 12rpx 28rpx rgba(255, 149, 0, 0.12);
}
.interaction-head {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:20rpx;
}
.interaction-title {
  font-size:32rpx;
  font-weight:600;
  color:#1f2430;
}
.interaction-round {
  margin-top:10rpx;
  font-size:24rpx;
  color:#667085;
}
.interaction-current {
  margin-top:16rpx;
  font-size:24rpx;
  color:#555;
}
.state-badge {
  flex:0 0 auto;
  min-width:148rpx;
  padding:10rpx 18rpx;
  border-radius:999rpx;
  font-size:22rpx;
  font-weight:600;
  text-align:center;
  box-sizing:border-box;
}
.state-badge--idle {
  background:#edf1f7;
  color:#5b6573;
}
.state-badge--active {
  background:#e8f1ff;
  color:#2f77ff;
}
.state-badge--pending {
  background:#fff3e0;
  color:#c97a00;
}
.state-badge--done {
  background:#e7f8ef;
  color:#00a870;
}
.interaction-status-panel {
  margin-top:20rpx;
  padding:22rpx 24rpx;
  border-radius:20rpx;
  background:#f8faff;
  border:1rpx solid #e5edff;
}
.student-focus {
  display:flex;
  flex-direction:column;
}
.student-focus-label {
  font-size:22rpx;
  color:#667085;
}
.student-focus-name {
  margin-top:10rpx;
  font-size:40rpx;
  line-height:1.2;
  font-weight:700;
  color:#1f2430;
}
.student-focus-meta {
  margin-top:10rpx;
  font-size:24rpx;
  color:#667085;
}
.status-copy {
  display:flex;
  flex-direction:column;
}
.status-copy-title {
  font-size:22rpx;
  color:#667085;
}
.status-copy-main {
  margin-top:10rpx;
  font-size:30rpx;
  line-height:1.4;
  font-weight:600;
  color:#1f2430;
}
.status-copy-sub {
  margin-top:10rpx;
  font-size:24rpx;
  line-height:1.5;
  color:#667085;
}
.action-section {
  margin-top:20rpx;
}
.primary-action {
  margin:0;
  height:84rpx;
  line-height:84rpx;
  border-radius:20rpx;
  background:#2f77ff;
  color:#fff;
  font-size:30rpx;
  font-weight:600;
  box-shadow:0 10rpx 22rpx rgba(47, 119, 255, 0.22);
}
.primary-action[disabled] {
  background:#c7d6f2;
  color:#fff;
  box-shadow:none;
}
.primary-action--disabled {
  opacity:1;
}
.action-hint {
  margin-top:16rpx;
  font-size:24rpx;
  color:#667085;
}
.score-panel {
  margin-top:18rpx;
  padding:20rpx 22rpx;
  border-radius:20rpx;
  background:#fff8ed;
  border:1rpx solid #ffe0b3;
}
.score-panel-title {
  font-size:24rpx;
  font-weight:600;
  color:#9a6700;
}
.score-btn-group {
  display:flex;
  flex-wrap:wrap;
  gap:12rpx;
  margin-top:16rpx;
}
.score-btn {
  margin:0;
  min-width:140rpx;
  background:#fff;
  color:#9a6700;
  border:1rpx solid #ffd089;
  border-radius:999rpx;
  line-height:1.6;
}
.lesson-section {
  margin-bottom:20rpx;
  background:#fff;
  border-radius:20rpx;
  padding:20rpx;
  box-shadow:0 8rpx 20rpx rgba(31, 36, 48, 0.05);
}
.lesson-header { margin-bottom:12rpx; }
.lesson-title { font-size:26rpx; font-weight:600; color:#333; }
.lesson-scroll { white-space:nowrap; }
.lesson-list { display:flex; }
.lesson-item {
  flex:0 0 auto; width:220rpx; margin-right:16rpx; padding:18rpx 20rpx;
  border-radius:18rpx; background:#f4f6f8; box-sizing:border-box;
  border:1rpx solid transparent;
}
.lesson-item.active {
  background:#e8f1ff;
  border-color:#b8d0ff;
}
.lesson-item-title {
  display:block; font-size:24rpx; color:#333; font-weight:600; margin-bottom:8rpx;
}
.lesson-item-id {
  display:block; font-size:20rpx; color:#666; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}
.lesson-empty { font-size:22rpx; color:#999; padding:12rpx 0; }

.list-container { padding-top:860rpx; padding-bottom:40rpx; }

.card {
  background:#fff; border-radius:20rpx; margin:0 20rpx 20rpx; padding:30rpx;
}
.info { display:flex; justify-content:space-between; }
.name { font-size:32rpx; }
.sub { margin-top:12rpx; font-size:24rpx; color:#666; }
.interaction-result-box {
  margin-top:18rpx;
  padding:16rpx 20rpx;
  background:#f7faff;
  border-radius:16rpx;
}
.interaction-result-row {
  margin-top:0;
}
.interaction-result-row + .interaction-result-row {
  margin-top:10rpx;
}
.question-btn-row {
  display:flex;
  flex-wrap:wrap;
  gap:12rpx;
  margin-top:20rpx;
}
.question-btn {
  margin:0;
  background:#eef4ff;
  color:#2f77ff;
  border-radius:999rpx;
  line-height:1.6;
}
.event-list {
  margin:0 20rpx 20rpx;
}
.event-item {
  background:#fff;
  border-radius:20rpx;
  padding:24rpx 30rpx;
  margin-bottom:20rpx;
  box-shadow:0 8rpx 20rpx rgba(31, 36, 48, 0.05);
}
.event-type,
.event-round {
  color:#2f77ff;
}
.event-round {
  margin-left:14rpx;
}
.event-score {
  font-size:28rpx;
  font-weight:600;
  color:#00a870;
}
.status { font-size:24rpx; padding:6rpx 14rpx; border-radius:50rpx; }

.signed { background:#e6fffa; color:#00c48c; }
.unsigned { background:#f2f3f5; color:#666; }
.absent { background:#fff1f0; color:#f53f3f; }
.leave_wait { background:#fff7e8; color:#ff9500; }
.leave_agree { background:#f8f0ff; color:#722ed1; }

.leave-box { background:#f9f7ff; border-radius:16rpx; padding:20rpx; margin:20rpx 0; }
.leave-img { width:100%; height:240rpx; border-radius:12rpx; }
.agree-btn { background:#722ed1; color:#fff; margin-top:16rpx; }

.btn-row { display:flex; gap:16rpx; margin-top:20rpx; }
.btn { flex:1; height:68rpx; line-height:68rpx; font-size:24rpx; border-radius:12rpx; background:#f2f5f9; }
.btn.on { background:#2f77ff; color:#fff; }

.empty { text-align:center; color:#aaa; margin-top:200rpx; }

/* 在最后面加一行即可 */
.clear-leave-btn { background: #ff4444; color: #fff; margin-top: 16rpx; }
