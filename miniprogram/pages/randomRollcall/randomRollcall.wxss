.rollcall-page {
  align-items: stretch;
  padding-top: 0;
}

.rollcall-hero {
  margin-bottom: 4rpx;
}

.rollcall-hero-status {
  margin-top: 0;
}

.focus-card,
.action-card,
.lesson-switch-card,
.history-card {
  margin-top: 0;
}

.rollcall-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ui-space-4);
}

.rollcall-stage__summary {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.rollcall-stage__headline {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  text-align: center;
}

.rollcall-stage__title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
}

.rollcall-stage__desc {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.dice-stage {
  position: relative;
  width: 100%;
  padding: 12rpx 0 20rpx;
  overflow: hidden;
}

.dice-stage__glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 420rpx;
  height: 220rpx;
  margin-left: -210rpx;
  margin-top: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.16) 0%, rgba(37, 99, 235, 0.04) 54%, rgba(37, 99, 235, 0) 100%);
  filter: blur(16rpx);
  pointer-events: none;
}

.dice-stage__shadow {
  position: absolute;
  bottom: 12rpx;
  width: 162rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.09);
  filter: blur(8rpx);
  transform: translateX(-50%);
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.dice-stage__shadow--left {
  left: calc(50% - 98rpx);
}

.dice-stage__shadow--right {
  left: calc(50% + 98rpx);
}

.dice-stage--rolling .dice-stage__shadow--left {
  transform: translateX(-50%) scale(0.82);
  opacity: 0.7;
}

.dice-stage--rolling .dice-stage__shadow--right {
  transform: translateX(-50%) scale(0.86);
  opacity: 0.75;
}

.dice-pair {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  min-height: 300rpx;
  z-index: 1;
}

.dice-pair__operator {
  width: 44rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(37, 99, 235, 0.72);
}

.dice-face-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.dice-face {
  width: 184rpx;
  height: 184rpx;
  padding: 22rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef5ff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  box-shadow: 0 14rpx 32rpx rgba(37, 99, 235, 0.12);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  box-sizing: border-box;
  transform-origin: center center;
  transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
}

.dice-face--left {
  transform: rotate(-10deg);
}

.dice-face--right {
  transform: rotate(12deg);
}

.dice-face--rolling {
  animation: dice-roll 0.72s ease-in-out;
  box-shadow: 0 18rpx 38rpx rgba(37, 99, 235, 0.18);
  filter: saturate(1.02);
}

.dice-cell {
  display: flex;
  align-items: center;
  justify-content: center;
}

.dice-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  transition: transform 0.16s ease, opacity 0.16s ease, background 0.16s ease;
}

.dice-dot--active {
  background: var(--ui-color-primary);
  box-shadow: 0 4rpx 10rpx rgba(37, 99, 235, 0.18);
}

.dice-dot--inactive {
  opacity: 0;
  transform: scale(0.6);
}

.dice-face-card__value {
  min-width: 104rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--ui-radius-pill);
  background: var(--ui-color-primary-soft);
  color: var(--ui-color-primary-strong);
  font-size: var(--ui-font-xs);
  font-weight: 600;
  text-align: center;
}

.rollcall-result-card {
  width: 100%;
}

.rollcall-result {
  display: flex;
  flex-direction: column;
  gap: var(--ui-space-3);
}

.rollcall-result--pending {
  align-items: center;
  text-align: center;
}

.rollcall-result__math {
  font-size: var(--ui-font-lg);
  font-weight: 700;
  line-height: 1.5;
  color: var(--ui-color-text);
  text-align: center;
}

.rollcall-result__student {
  display: flex;
  align-items: center;
  gap: var(--ui-space-3);
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
}

.rollcall-result__avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--ui-color-primary-soft) 0%, #dbeafe 100%);
  color: var(--ui-color-primary);
  font-size: 36rpx;
  font-weight: 700;
  border: 1rpx solid var(--ui-color-primary-border);
}

.rollcall-result__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rollcall-result__name {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--ui-color-text);
}

.rollcall-result__meta,
.rollcall-result__summary {
  font-size: var(--ui-font-sm);
  line-height: 1.75;
  color: var(--ui-color-text-muted);
}

.rollcall-result__placeholder {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-primary);
}

.rollcall-result__hint {
  margin-top: 0;
  text-align: center;
}

.score-panel {
  margin-top: 6rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--ui-color-warning-soft);
  border: 1rpx solid var(--ui-color-warning-border);
}

.score-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #b45309;
}

.score-btn {
  margin: 0;
  flex: 1 1 180rpx;
  min-width: 180rpx;
  line-height: 1.6;
}

.history-record-card {
  gap: 10rpx;
}

.event-score {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ui-color-success);
  align-self: flex-start;
}

.event-round {
  color: var(--ui-color-primary);
}

.primary-action {
  margin: 0;
  min-height: var(--ui-button-height);
  font-size: 32rpx;
  border-radius: 999rpx !important;
}

.primary-action--disabled {
  opacity: 1;
}

@keyframes dice-roll {
  0% {
    transform: translateY(0) rotate(-8deg) scale(1);
  }

  25% {
    transform: translateY(-10rpx) rotate(10deg) scale(1.03);
  }

  50% {
    transform: translateY(6rpx) rotate(-14deg) scale(0.98);
  }

  75% {
    transform: translateY(-4rpx) rotate(8deg) scale(1.01);
  }

  100% {
    transform: translateY(0) rotate(0deg) scale(1);
  }
}
