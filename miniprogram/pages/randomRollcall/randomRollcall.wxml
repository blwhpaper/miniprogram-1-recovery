<view class="rollcall-page ui-page ui-page--stack">
  <view class="rollcall-hero ui-hero-section">
    <view class="ui-hero-section__content">
      <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll ui-scroll-x rollcall-lesson-scroll" scroll-x="true" show-scrollbar="false">
        <view class="ui-chip-list rollcall-lesson-list">
          <view
            wx:for="{{lessons}}"
            wx:key="_id"
            class="ui-chip-card rollcall-lesson-card {{selectedLessonId === item._id ? 'ui-chip-card--active' : ''}}"
            bindtap="onSelectLesson"
            hover-class="ui-btn-active"
            data-lesson-id="{{item._id}}"
          >
            <text class="ui-chip-title">{{item.orderLabel}}</text>
          </view>
        </view>
      </scroll-view>
      <view wx:else class="ui-empty-state rollcall-lesson-empty">
        <view class="ui-empty-title">暂无课次</view>
      </view>
    </view>
  </view>
  <view class="rollcall-hero-placeholder"></view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryPageLoad">重试</button>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card--focus focus-card">
    <view class="rollcall-stage">
      <view class="rollcall-stage__deck">
        <view class="number-card-stage {{displayPhase === 'rolling' ? 'number-card-stage--rolling' : ''}}">
          <view class="number-card-stage__glow"></view>
          <view class="number-card-stage__halo"></view>
          <view class="number-card-pair">
            <view class="number-card-face number-card-face--left number-card-face--{{displayPhase === 'verify' ? 'verify' : ((displayPhase === 'countdown') ? 'countdown' : ((displayPhase === 'warning' || displayPhase === 'finished') ? 'danger' : 'idle'))}} {{displayPhase === 'rolling' ? 'number-card-face--rolling' : ''}}">
              <view class="number-card-face__corner">
                <text class="number-card-face__corner-text">{{displayPhase === 'rolling' ? (diceLeftText || '0') : (displayLeftText || '0')}}</text>
                <text class="number-card-face__corner-mark">{{displayPhase === 'countdown' || displayPhase === 'warning' || displayPhase === 'finished' ? '⏱' : '♠'}}</text>
              </view>
              <view class="number-card-face__digit">{{displayPhase === 'rolling' ? (diceLeftText || '0') : (displayLeftText || '0')}}</view>
              <view class="number-card-face__corner number-card-face__corner--bottom">
                <text class="number-card-face__corner-text">{{displayPhase === 'rolling' ? (diceLeftText || '0') : (displayLeftText || '0')}}</text>
                <text class="number-card-face__corner-mark">{{displayPhase === 'countdown' || displayPhase === 'warning' || displayPhase === 'finished' ? '⏱' : '♠'}}</text>
              </view>
              <view wx:if="{{displayPhase === 'verify'}}" class="number-card-face__footer">ID-1</view>
            </view>
            <view class="number-card-face number-card-face--right number-card-face--{{displayPhase === 'verify' ? 'verify' : ((displayPhase === 'countdown') ? 'countdown' : ((displayPhase === 'warning' || displayPhase === 'finished') ? 'danger' : 'idle'))}} {{displayPhase === 'rolling' ? 'number-card-face--rolling' : ''}}">
              <view class="number-card-face__corner">
                <text class="number-card-face__corner-text">{{displayPhase === 'rolling' ? (diceRightText || '0') : (displayRightText || '0')}}</text>
                <text class="number-card-face__corner-mark">{{displayPhase === 'countdown' || displayPhase === 'warning' || displayPhase === 'finished' ? '⏱' : '♥'}}</text>
              </view>
              <view class="number-card-face__digit">{{displayPhase === 'rolling' ? (diceRightText || '0') : (displayRightText || '0')}}</view>
              <view class="number-card-face__corner number-card-face__corner--bottom">
                <text class="number-card-face__corner-text">{{displayPhase === 'rolling' ? (diceRightText || '0') : (displayRightText || '0')}}</text>
                <text class="number-card-face__corner-mark">{{displayPhase === 'countdown' || displayPhase === 'warning' || displayPhase === 'finished' ? '⏱' : '♥'}}</text>
              </view>
              <view wx:if="{{displayPhase === 'verify'}}" class="number-card-face__footer">ID-2</view>
              <view wx:if="{{displayPhase === 'countdown' || displayPhase === 'warning' || displayPhase === 'finished'}}" class="number-card-face__footer">SEC</view>
            </view>
          </view>
        </view>
      </view>

      <view class="rollcall-result-card ui-card ui-section ui-panel-card {{displayPhase !== 'idle' ? 'ui-panel-card--focus' : ''}}">
        <view class="rollcall-result-card__shine"></view>

        <block wx:if="{{displayPhase !== 'idle'}}">
          <view wx:if="{{displayPhase === 'rolling'}}" class="rollcall-result rollcall-result--rolling">
            <view class="rollcall-result__student">
              <view class="rollcall-result__content rollcall-result__content--full">
                <view class="rollcall-result__name rollcall-result__name--rolling">幸运锁定中…</view>
              </view>
            </view>
          </view>

          <view wx:else class="rollcall-result">
            <view class="rollcall-result__student">
              <view class="rollcall-result__content rollcall-result__content--full">
                <view class="rollcall-result__name">{{(currentCalledStudent && currentCalledStudent.name) || ''}}</view>

                <view wx:if="{{displayPhase === 'verify'}}" class="rollcall-result__verify">
                  <view class="rollcall-result__verify-bar">
                    <view class="rollcall-result__verify-fill" style="width: {{verifyProgressPercent}}%;"></view>
                    <view class="rollcall-result__verify-label">学号核对中 {{verifySecondsLeft}}S</view>
                  </view>
                </view>

                <view wx:elif="{{displayPhase === 'countdown' || displayPhase === 'warning'}}" class="rollcall-result__status-pill rollcall-result__status-pill--{{displayPhase === 'warning' ? 'danger' : 'countdown'}}">
                  🕙 正在倒计时
                </view>

                <view wx:elif="{{displayPhase === 'finished'}}" class="rollcall-result__status-pill rollcall-result__status-pill--danger">
                  思考时间结束
                </view>
              </view>
            </view>
          </view>
        </block>

        <view wx:else class="rollcall-result rollcall-result--idle">
          <view class="rollcall-result__idle-title">READY FOR SELECTION</view>
          <view class="rollcall-result__idle-desc">选中后学号展示 10s 后自动开启倒计时</view>
        </view>
      </view>

      <view wx:if="{{displayPhase !== 'idle'}}" class="score-panel {{selectedLessonId === currentManagedLessonId ? '' : 'score-panel--disabled'}}">
        <view class="score-panel__shine"></view>
        <view class="score-panel-title">{{displayPhase === 'rolling' || displayPhase === 'verify' ? '预备评分' : '课堂表现评分（计时中）'}}</view>
        <view class="ui-record-actions">
          <button
            wx:for="{{interactionScoreOptions}}"
            wx:key="*this"
            class="score-chip {{selectedScore === item ? 'score-chip--active' : ''}}"
            size="mini"
            bindtap="onTapScoreAnswer"
            hover-class="ui-btn-active"
            data-score="{{item}}"
          >
            {{item}}分
          </button>
        </view>
      </view>

      <view wx:if="{{displayPhase === 'idle'}}" class="rollcall-action-bar">
        <button
          class="rollcall-action-btn rollcall-action-btn--primary {{displayPhase !== 'idle' || !selectedLessonId || signedStudents.length === 0 || selectedLessonId !== currentManagedLessonId ? 'rollcall-action-btn--disabled' : ''}}"
          bindtap="onTapRandomRollcall"
          disabled="{{displayPhase !== 'idle' || !selectedLessonId || signedStudents.length === 0 || selectedLessonId !== currentManagedLessonId}}"
          hover-class="ui-btn-active"
        >
          READY? | GO!
        </button>
      </view>

      <view wx:elif="{{displayPhase !== 'idle'}}" class="rollcall-action-row">
        <button class="rollcall-action-btn rollcall-action-btn--ghost" bindtap="onTapReplaceStudent" hover-class="ui-btn-active">
          <text class="rollcall-action-btn__icon">↺</text>
          <text>换一个</text>
        </button>
        <button
          class="rollcall-action-btn rollcall-action-btn--primary {{(!selectedScore || recordSubmitting) ? 'rollcall-action-btn--disabled' : ''}}"
          bindtap="onTapRecordResult"
          disabled="{{!selectedScore || recordSubmitting}}"
          hover-class="ui-btn-active"
        >
          记录结果
        </button>
      </view>

      <view class="history-card ui-card ui-section ui-panel-card">
        <view class="ui-card-head">
          <view class="ui-title-md">历史记录</view>
        </view>

        <view wx:if="{{lessonEventsLoading}}" class="ui-state-block ui-loading-state">
          <view class="ui-state-title">加载中</view>
        </view>

        <scroll-view wx:elif="{{displayLessonEvents.length > 0}}" class="history-scroll ui-scroll-x" scroll-x="true" show-scrollbar="false">
          <view class="history-record-list history-record-list--x">
            <view class="ui-record-card ui-record-card--muted history-record-card" wx:for="{{displayLessonEvents}}" wx:key="_id">
              <view class="history-record-card__bar"></view>
              <view class="ui-record-head history-record-card__head">
                <view class="history-record-card__name">{{item.studentName || '未命名学生'}}</view>
                <view class="event-score">{{item.score}}分</view>
              </view>
            </view>
          </view>
        </scroll-view>

        <view wx:else class="ui-empty-state">
          <view class="ui-empty-title">暂无记录</view>
        </view>
      </view>
    </view>
  </view>
</view>
