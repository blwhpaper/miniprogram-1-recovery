<view class="rollcall-page ui-page ui-page--stack">
  <view class="ui-card ui-hero-card ui-hero-card--teacher ui-section rollcall-hero">
    <view class="ui-card-head ui-page-head">
      <view class="ui-card-head hero-main ui-page-head-main">
        <view class="ui-title-lg">随机点名</view>
        <view class="ui-text-helper">第{{currentRound}}轮</view>
      </view>
      <view
        class="ui-tag {{pendingScoreLock ? 'ui-tag--pending' : ''}} {{!pendingScoreLock && currentCalledStudent ? 'ui-tag--active' : ''}} {{!pendingScoreLock && !currentCalledStudent && lastScoredStudentName ? 'ui-tag--approved' : ''}} {{!pendingScoreLock && !currentCalledStudent && !lastScoredStudentName ? 'ui-tag--inactive' : ''}}"
      >
        <text wx:if="{{pendingScoreLock}}">待评分</text>
        <text wx:elif="{{currentCalledStudent}}">点名中</text>
        <text wx:elif="{{lastScoredStudentName}}">可继续下一位</text>
        <text wx:else>未开始</text>
      </view>
    </view>
  </view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryPageLoad">重试</button>
    </view>
  </view>

  <view class="ui-card ui-status-card ui-section ui-panel-card--focus focus-card">
    <view wx:if="{{currentCalledStudent}}" class="ui-card-head">
      <view class="ui-title-lg">{{currentCalledStudent.name}}</view>
      <view class="ui-text-body">学号：{{currentCalledStudent.studentId || '-'}}</view>
    </view>

    <view wx:elif="{{lastScoredStudentName}}" class="ui-card-head">
      <view class="ui-title-md">{{lastScoredStudentName}} 已完成第{{lastScoredRound}}轮</view>
    </view>

    <view wx:elif="{{selectedLessonId && signedStudents.length > 0}}" class="ui-card-head">
      <view class="ui-title-md">已签到 {{signedStudents.length}} 人</view>
    </view>

    <view wx:elif="{{selectedLessonId}}" class="ui-card-head">
      <view class="ui-title-md">暂无可点名学生</view>
    </view>

    <view wx:else class="ui-card-head">
      <view class="ui-title-md">暂无课次</view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card action-card">
    <view class="ui-card-head">
      <view class="ui-title-md">操作</view>
    </view>

    <button
      class="primary-action {{pendingScoreLock ? 'primary-action--disabled' : ''}}"
      bindtap="onTapRandomRollcall"
      hover-class="ui-btn-active"
      disabled="{{pendingScoreLock || !selectedLessonId || signedStudents.length === 0}}"
    >
      {{currentCalledStudent || pendingScoreLock ? '继续' : '随机点名'}}
    </button>

    <view wx:if="{{pendingScoreLock && currentCalledStudent}}" class="score-panel">
      <view class="score-panel-title">给 {{currentCalledStudent.name}} 评分</view>
      <view class="ui-record-actions">
        <button
          wx:for="{{interactionScoreOptions}}"
          wx:key="*this"
          class="ui-btn-pill ui-btn-pill--warning score-btn"
          size="mini"
          bindtap="onTapScoreAnswer"
          hover-class="ui-btn-active"
          data-score="{{item}}"
        >
          {{item}}分
        </button>
      </view>
    </view>

    <view wx:else class="ui-text-muted">
      <text wx:if="{{selectedLessonId && signedStudents.length > 0}}">可点名</text>
      <text wx:elif="{{selectedLessonId}}">暂无已签到学生</text>
      <text wx:else>暂无课次</text>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card lesson-switch-card">
    <view class="ui-card-head">
      <view class="ui-title-md">历史课次</view>
    </view>
    <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll ui-scroll-x" scroll-x="true" show-scrollbar="false">
      <view class="ui-chip-list">
        <view
          wx:for="{{lessons}}"
          wx:key="_id"
          class="ui-chip-card {{selectedLessonId === item._id ? 'ui-chip-card--active' : ''}}"
          bindtap="onSelectLesson"
          hover-class="ui-btn-active"
          data-lesson-id="{{item._id}}"
        >
          <text class="ui-chip-title">课次 {{lessons.length - index}}</text>
          <text class="ui-chip-meta">{{item._id}}</text>
        </view>
      </view>
    </scroll-view>
    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无历史课次</view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card history-card">
    <view class="ui-card-head">
      <view class="ui-title-md">本节互动记录</view>
    </view>

    <view wx:if="{{lessonEventsLoading}}" class="ui-state-block ui-loading-state">
      <view class="ui-state-title">加载中</view>
    </view>

    <view wx:elif="{{lessonEvents.length > 0}}" class="ui-record-list">
      <view class="ui-record-card ui-record-card--muted history-record-card" wx:for="{{lessonEvents}}" wx:key="_id">
        <view class="ui-record-head">
          <view class="ui-card-head">
            <view class="ui-title-md">{{item.studentName || '未命名学生'}}</view>
            <view class="ui-text-helper">{{item.displayType}}</view>
          </view>
          <view class="event-score" wx:if="{{item.score}}">+{{item.score}}</view>
        </view>
        <view class="ui-text-muted">
          <text wx:if="{{item.round}}" class="event-round">第{{item.round}}轮</text>
        </view>
        <view class="ui-text-helper">{{item.displayTime}}</view>
      </view>
    </view>

    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无记录</view>
    </view>
  </view>
</view>
