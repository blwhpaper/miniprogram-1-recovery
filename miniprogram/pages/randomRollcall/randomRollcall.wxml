<view class="rollcall-page ui-page ui-page--stack ui-page--with-bottom-bar">
  <view class="rollcall-hero ui-hero-section">
    <view class="ui-hero-section__content">
      <view class="ui-hero-section__head">
        <view class="ui-card-head ui-page-head-main">
          <view class="ui-hero-section__desc">双骰子动态点名页</view>
          <view class="ui-hero-section__title">随机点名</view>
        </view>
        <view class="ui-hero-pill">第{{currentRound}}轮</view>
      </view>
      <view
        class="rollcall-hero-status ui-feedback {{pendingScoreLock ? 'ui-feedback--warning' : currentCalledStudent ? 'ui-feedback--success' : lastScoredStudentName ? 'ui-feedback--info' : 'ui-feedback--idle'}}"
      >
        <text wx:if="{{pendingScoreLock}}">当前结果待评分</text>
        <text wx:elif="{{currentCalledStudent}}">已抽中学生，等待教师评分</text>
        <text wx:elif="{{lastScoredStudentName}}">上一位已完成，可继续下一轮</text>
        <text wx:else>点击按钮开始随机点名</text>
      </view>
    </view>
  </view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryPageLoad">重试</button>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card--focus focus-card">
    <view class="rollcall-stage">
      <view class="rollcall-stage__summary">全班学生：{{signedStudents.length || 0}} 人</view>
      <view class="rollcall-stage__headline">
        <view class="rollcall-stage__title">{{isRolling ? '正在投掷双骰子' : '点击开始进行骰子点名'}}</view>
        <view class="rollcall-stage__desc">
          <text wx:if="{{isRolling}}">系统正在生成本轮结果，请稍候片刻。</text>
          <text wx:elif="{{currentCalledStudent}}">骰子结果：{{diceLeftValue}} + {{diceRightValue}}</text>
          <text wx:elif="{{lastScoredStudentName}}">上一轮已完成，可继续下一轮点名。</text>
          <text wx:else>当前页面只做表现增强，不改既有随机点名业务规则。</text>
        </view>
      </view>
      <view class="dice-stage {{isRolling ? 'dice-stage--rolling' : ''}}">
        <view class="dice-stage__glow"></view>
        <view class="dice-stage__shadow dice-stage__shadow--left"></view>
        <view class="dice-stage__shadow dice-stage__shadow--right"></view>
        <view class="dice-pair">
          <view class="dice-face-card dice-face-card--left">
            <view class="dice-face dice-face--left {{isRolling ? 'dice-face--rolling' : ''}}">
              <view wx:for="{{leftDicePips}}" wx:key="key" class="dice-cell">
                <view class="dice-dot {{item.active ? 'dice-dot--active' : 'dice-dot--inactive'}}"></view>
              </view>
            </view>
            <view class="dice-face-card__value">左骰 {{diceLeftValue}}</view>
          </view>
          <view class="dice-pair__operator">+</view>
          <view class="dice-face-card dice-face-card--right">
            <view class="dice-face dice-face--right {{isRolling ? 'dice-face--rolling' : ''}}">
              <view wx:for="{{rightDicePips}}" wx:key="key" class="dice-cell">
                <view class="dice-dot {{item.active ? 'dice-dot--active' : 'dice-dot--inactive'}}"></view>
              </view>
            </view>
            <view class="dice-face-card__value">右骰 {{diceRightValue}}</view>
          </view>
        </view>
      </view>

      <view class="rollcall-result-card ui-card ui-section ui-panel-card {{currentCalledStudent ? 'ui-panel-card--focus' : ''}}">
        <view class="ui-card-head ui-card-head--row">
          <view class="ui-card-head">
            <view class="ui-eyebrow">点名结果</view>
            <view class="ui-title-md">
              <text wx:if="{{isRolling}}">正在抽取本轮学生</text>
              <text wx:elif="{{currentCalledStudent}}">第{{currentCalledStudent.round || currentRound}}轮已抽中</text>
              <text wx:elif="{{lastScoredStudentName}}">上一轮已完成</text>
              <text wx:elif="{{selectedLessonId && signedStudents.length > 0}}">等待开始点名</text>
              <text wx:elif="{{selectedLessonId}}">暂无可点名学生</text>
              <text wx:else>暂无课次</text>
            </view>
          </view>
          <view wx:if="{{currentCalledStudent}}" class="ui-tag ui-tag--active">待评分</view>
          <view wx:elif="{{isRolling}}" class="ui-tag ui-tag--pending">点名中</view>
          <view wx:elif="{{lastScoredStudentName}}" class="ui-tag ui-tag--approved">已完成</view>
        </view>

        <view wx:if="{{currentCalledStudent}}" class="rollcall-result">
          <view class="rollcall-result__math">骰子结果：{{diceLeftValue}} + {{diceRightValue}}</view>
          <view class="rollcall-result__student">
            <view class="rollcall-result__avatar">{{currentCalledStudent.avatarText || '学'}}</view>
            <view class="rollcall-result__content">
              <view class="rollcall-result__name">{{currentCalledStudent.name}}</view>
              <view class="rollcall-result__meta">学号：{{currentCalledStudent.studentId || '-'}}</view>
              <view class="rollcall-result__meta">当前轮次：第{{currentCalledStudent.round || currentRound}}轮</view>
            </view>
          </view>
          <view class="rollcall-result__hint ui-feedback ui-feedback--warning">请在下方完成评分后再进入下一轮。</view>
        </view>

        <view wx:elif="{{isRolling}}" class="rollcall-result rollcall-result--pending">
          <view class="rollcall-result__math">骰子正在滚动，请保持当前页面。</view>
          <view class="rollcall-result__placeholder">结果即将落定</view>
        </view>

        <view wx:elif="{{lastScoredStudentName}}" class="rollcall-result">
          <view class="rollcall-result__math">上一轮结果已记录</view>
          <view class="rollcall-result__summary">{{lastScoredStudentName}} 已完成第{{lastScoredRound}}轮评分，可继续下一轮。</view>
        </view>

        <view wx:elif="{{selectedLessonId && signedStudents.length > 0}}" class="rollcall-result">
          <view class="rollcall-result__math">当前可点名 {{signedStudents.length}} 人</view>
          <view class="rollcall-result__summary">点击下方按钮开始本轮随机点名，系统会自动记录抽中结果。</view>
        </view>

        <view wx:elif="{{selectedLessonId}}" class="rollcall-result">
          <view class="rollcall-result__summary">当前课次还没有已签到学生，暂时无法进行随机点名。</view>
        </view>

        <view wx:else class="rollcall-result">
          <view class="rollcall-result__summary">请先选择一个有数据的历史课次，再开始随机点名。</view>
        </view>
      </view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card action-card">
    <view class="ui-card-head">
      <view class="ui-title-md">操作</view>
    </view>

    <view wx:if="{{pendingScoreLock && currentCalledStudent}}" class="score-panel">
      <view class="score-panel-title">给 {{currentCalledStudent.name}} 评分</view>
      <view class="ui-record-actions">
        <button
          wx:for="{{interactionScoreOptions}}"
          wx:key="*this"
          class="ui-btn-pill ui-btn-pill--warning score-btn"
          size="mini"
          bindtap="onTapScoreAnswer"
          hover-class="ui-btn-active"
          data-score="{{item}}"
        >
          {{item}}分
        </button>
      </view>
    </view>

    <view wx:else class="ui-text-muted">
      <text wx:if="{{selectedLessonId && signedStudents.length > 0}}">可点名</text>
      <text wx:elif="{{selectedLessonId}}">暂无已签到学生</text>
      <text wx:else>暂无课次</text>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card lesson-switch-card">
    <view class="ui-card-head">
      <view class="ui-title-md">历史课次</view>
    </view>
    <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll ui-scroll-x" scroll-x="true" show-scrollbar="false">
      <view class="ui-chip-list">
        <view
          wx:for="{{lessons}}"
          wx:key="_id"
          class="ui-chip-card {{selectedLessonId === item._id ? 'ui-chip-card--active' : ''}}"
          bindtap="onSelectLesson"
          hover-class="ui-btn-active"
          data-lesson-id="{{item._id}}"
        >
          <text class="ui-chip-title">课次 {{lessons.length - index}}</text>
          <text class="ui-chip-meta">{{item._id}}</text>
        </view>
      </view>
    </scroll-view>
    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无历史课次</view>
    </view>
  </view>

  <view class="ui-card ui-section ui-panel-card history-card">
    <view class="ui-card-head">
      <view class="ui-title-md">本节互动记录</view>
    </view>

    <view wx:if="{{lessonEventsLoading}}" class="ui-state-block ui-loading-state">
      <view class="ui-state-title">加载中</view>
    </view>

    <view wx:elif="{{lessonEvents.length > 0}}" class="ui-record-list">
      <view class="ui-record-card ui-record-card--muted history-record-card" wx:for="{{lessonEvents}}" wx:key="_id">
        <view class="ui-record-head">
          <view class="ui-card-head">
            <view class="ui-title-md">{{item.studentName || '未命名学生'}}</view>
            <view class="ui-text-helper">{{item.displayType}}</view>
          </view>
          <view class="event-score" wx:if="{{item.score}}">+{{item.score}}</view>
        </view>
        <view class="ui-text-muted">
          <text wx:if="{{item.round}}" class="event-round">第{{item.round}}轮</text>
        </view>
        <view class="ui-text-helper">{{item.displayTime}}</view>
      </view>
    </view>

    <view wx:else class="ui-empty-state">
      <view class="ui-empty-title">暂无记录</view>
    </view>
  </view>

  <view class="ui-bottom-bar">
    <view class="ui-bottom-bar__content">
      <view class="ui-bottom-bar__hint">
        <text wx:if="{{selectedLessonId && signedStudents.length > 0}}">点击开始进行本轮随机点名</text>
        <text wx:elif="{{selectedLessonId}}">当前课次暂无已签到学生</text>
        <text wx:else>请先选择有数据的历史课次</text>
      </view>
      <view class="ui-bottom-bar__actions">
        <button
          class="primary-action {{pendingScoreLock ? 'primary-action--disabled' : ''}}"
          bindtap="onTapRandomRollcall"
          hover-class="ui-btn-active"
          disabled="{{isRolling || pendingScoreLock || !selectedLessonId || signedStudents.length === 0}}"
        >
          {{isRolling ? '点名中' : currentCalledStudent || pendingScoreLock || lastScoredStudentName ? '再抽一次' : '开始点名'}}
        </button>
      </view>
    </view>
  </view>
</view>
