<import src="../../shared/genieLamp/genieLamp.wxml" />
<view class="interaction-page ui-page ui-page--stack">
  <view class="interaction-hero ui-hero-section">
    <view class="ui-hero-section__content">
      <view class="ui-hero-section__head">
        <view class="ui-card-head ui-page-head-main">
          <view class="ui-hero-section__desc">教师处理学生主动提问请求</view>
          <view class="ui-hero-section__title">提问请求管理</view>
        </view>
        <view class="ui-hero-pill">{{selectedLessonId ? '当前课次' : '未选择课次'}}</view>
      </view>
      <view class="interaction-hero__stats">
        <view class="interaction-hero__stat">
          <view class="interaction-hero__stat-label">当前提问请求</view>
          <view class="interaction-hero__stat-value">{{pendingQuestionRequests.length}} 人</view>
        </view>
        <view class="interaction-hero__stat">
          <view class="interaction-hero__stat-label">处理状态</view>
          <view class="interaction-hero__stat-value">{{currentQuestionRequest ? '进行中' : '等待处理'}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{pageLoading}}" class="ui-state-block ui-loading-state">
    <view class="ui-state-title">加载中</view>
  </view>

  <view wx:elif="{{pageErrorText}}" class="ui-state-block ui-error-state">
    <view class="ui-state-title">加载失败</view>
    <view class="ui-state-desc">{{pageErrorText}}</view>
    <view class="ui-state-actions">
      <button class="ui-btn-ghost" size="mini" hover-class="ui-btn-active" bindtap="retryPageLoad">重试</button>
    </view>
  </view>

  <block wx:else>
    <view class="overview-card ui-card ui-section ui-panel-card ui-panel-card--focus">
      <view class="overview-card__row">
        <view class="overview-card__main">
          <view class="ui-title-md">当前提问请求：{{pendingQuestionRequests.length}} 人</view>
          <view class="overview-card__desc">{{currentQuestionRequest ? '当前已有学生获准发言，完成后可继续处理下一位。' : '按顺序处理学生申请，允许后学生端会自动收到结果。'}}</view>
        </view>
        <view class="ui-tag ui-tag--{{selectedLessonId ? 'active' : 'inactive'}}">{{selectedLessonId ? '申请通道已连接' : '暂无课次'}}</view>
      </view>
      <view class="overview-card__status ui-feedback ui-feedback--{{currentQuestionRequest ? 'success' : pendingQuestionRequests.length > 0 ? 'info' : 'idle'}}">
        {{currentQuestionRequest ? '当前正在处理 1 位学生的提问请求。' : pendingQuestionRequests.length > 0 ? '当前有待处理提问请求，请尽快处理。' : '当前暂无新的提问请求。'}}
      </view>
      <view class="ui-button-group">
        <button
          wx:if="{{selectedLessonId}}"
          class="ui-btn-secondary"
          hover-class="ui-btn-active"
          bindtap="goToRandomRollcall"
        >
          随机点名
        </button>
      </view>
    </view>

    <view class="lesson-switch-card ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="ui-title-md">历史课次</view>
      </view>
      <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll ui-scroll-x" scroll-x="true" show-scrollbar="false">
        <view class="ui-chip-list">
          <view
            wx:for="{{lessons}}"
            wx:key="_id"
            class="ui-chip-card {{selectedLessonId === item._id ? 'ui-chip-card--active' : ''}}"
            bindtap="onSelectLesson"
            hover-class="ui-btn-active"
            data-lesson-id="{{item._id}}"
          >
            <text class="ui-chip-title">课次 {{lessons.length - index}}</text>
            <text class="ui-chip-meta">{{item._id}}</text>
          </view>
        </view>
      </scroll-view>
      <view wx:else class="ui-empty-state">
        <view class="ui-empty-title">暂无历史课次</view>
      </view>
    </view>

    <view class="current-request-card ui-card ui-section ui-panel-card" wx:if="{{currentQuestionRequest}}">
      <view class="ui-card-head">
        <view class="ui-title-md">当前已允许发言</view>
        <view class="ui-tag ui-tag--active">{{currentQuestionRequest.statusTagText}}</view>
      </view>
      <view class="request-item request-item--active">
        <view class="request-item__main">
          <view class="request-avatar">
            <image wx:if="{{currentQuestionRequest.avatarUrl}}" class="request-avatar__img" src="{{currentQuestionRequest.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="request-avatar__fallback">{{currentQuestionRequest.avatarText}}</view>
          </view>
          <view class="request-item__content">
            <view class="request-item__name">{{currentQuestionRequest.studentName}}</view>
            <view class="request-item__meta">{{currentQuestionRequest.studentId || '学号待补充'}} · 允许时间 {{currentQuestionRequest.displayTime || '--'}}</view>
          </view>
        </view>
        <view class="score-actions ui-record-actions">
          <button
            wx:for="{{interactionScoreOptions}}"
            wx:key="*this"
            type="primary"
            size="mini"
            bindtap="onTapScoreQuestion"
            hover-class="ui-btn-active"
            data-score="{{item}}"
          >
            评分 {{item}}
          </button>
        </view>
      </view>
    </view>

    <view class="request-list-card ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="ui-title-md">请求列表</view>
      </view>

      <view wx:if="{{pendingQuestionRequests.length > 0}}" class="ui-record-list">
        <view class="request-item ui-record-card" wx:for="{{pendingQuestionRequests}}" wx:key="_id">
          <view class="request-item__main">
            <view class="request-avatar">
              <image wx:if="{{item.avatarUrl}}" class="request-avatar__img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <view wx:else class="request-avatar__fallback">{{item.avatarText}}</view>
            </view>
            <view class="request-item__content">
              <view class="request-item__name">{{item.studentName}}</view>
              <view class="request-item__meta">{{item.studentId || '学号待补充'}}</view>
              <view class="request-item__time">申请时间 {{item.displayTime || '--'}}</view>
            </view>
            <view class="ui-tag ui-tag--pending request-item__tag">{{item.statusTagText}}</view>
          </view>
          <view class="request-item__actions ui-record-actions">
            <button
              type="primary"
              size="mini"
              bindtap="onTapApproveQuestionRequest"
              hover-class="ui-btn-active"
              data-request-id="{{item._id}}"
              data-student-id="{{item.studentId}}"
              data-student-name="{{item.studentName}}"
            >
              允许
            </button>
            <button
              class="ui-btn-secondary"
              size="mini"
              bindtap="onTapDeferQuestionRequest"
              hover-class="ui-btn-active"
            >
              稍后
            </button>
          </view>
        </view>
      </view>

      <view wx:else class="request-empty ui-empty-state">
        <template is="genieLamp" data="{{ shellClass: 'request-empty__lamp-shell', lampClass: 'request-empty__lamp' }}" />
        <view class="ui-empty-title">暂无提问请求</view>
        <view class="ui-empty-desc">学生发起提问后，会在这里按顺序展示。</view>
      </view>
    </view>

    <view class="history-card ui-card ui-section ui-panel-card">
      <view class="ui-card-head">
        <view class="ui-title-md">处理记录</view>
      </view>

      <view wx:if="{{lessonEventsLoading}}" class="ui-state-block ui-loading-state">
        <view class="ui-state-title">加载中</view>
      </view>

      <view wx:elif="{{questionRequestHistory.length > 0}}" class="ui-record-list">
        <view class="ui-record-card ui-record-card--muted history-record-card" wx:for="{{questionRequestHistory}}" wx:key="_id">
          <view class="ui-record-head">
            <view class="ui-card-head">
              <view class="ui-title-md">{{item.studentName || '课堂提问记录'}}</view>
              <view class="ui-text-helper">{{item.displayType}}</view>
            </view>
            <view class="test-score" wx:if="{{item.score}}">+{{item.score}}</view>
          </view>
          <view class="ui-text-muted">{{item.displayTime}}</view>
        </view>
      </view>

      <view wx:else class="ui-empty-state">
        <view class="ui-empty-title">暂无处理记录</view>
      </view>
    </view>
  </block>
</view>
