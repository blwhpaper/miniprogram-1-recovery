
<view class="page">
  <view class="stats-fixed">
    <view class="interaction-card">
      <view class="interaction-title">课堂互动</view>
      <view class="interaction-current">
        <text>当前轮次：第{{currentRound}}轮</text>
      </view>
      <view class="score-btn-group">
        <button class="export-btn" size="mini" bindtap="onTapRandomRollcall">随机点名</button>
        <button class="export-btn export-btn-secondary" size="mini" bindtap="onTapPublishTestExample">发布测试样例</button>
      </view>
      <view class="interaction-current">
        <text wx:if="{{currentCalledStudent}}">
          当前点名：{{currentCalledStudent.name}}（{{currentCalledStudent.studentId || '-'}}）
        </text>
        <text wx:else>当前未点名</text>
      </view>
      <view wx:if="{{currentCalledStudent}}" class="score-btn-group">
        <button
          wx:for="{{interactionScoreOptions}}"
          wx:key="*this"
          class="score-btn"
          size="mini"
          bindtap="onTapScoreAnswer"
          data-score="{{item}}"
        >
          {{item}}分
        </button>
      </view>

      <view wx:if="{{pendingQuestionRequests.length > 0}}" class="event-list">
        <view class="lesson-header">
          <text class="lesson-title">待处理提问申请</text>
        </view>
        <view class="event-item" wx:for="{{pendingQuestionRequests}}" wx:key="_id">
          <view class="info">
            <text class="name">{{item.studentName}}</text>
          </view>
          <view class="sub">
            <text>{{item.displayTime}}</text>
          </view>
          <view class="score-btn-group">
            <button
              class="score-btn"
              size="mini"
              bindtap="onTapApproveQuestionRequest"
              data-request-id="{{item._id}}"
              data-student-id="{{item.studentId}}"
              data-student-name="{{item.studentName}}"
            >
              允许提问
            </button>
          </view>
        </view>
      </view>

      <view wx:if="{{currentQuestionRequest}}" class="interaction-current">
        <text>当前提问：{{currentQuestionRequest.studentName}}（{{currentQuestionRequest.studentId || '-'}}）</text>
      </view>
      <view wx:if="{{currentQuestionRequest}}" class="score-btn-group">
        <button
          wx:for="{{interactionScoreOptions}}"
          wx:key="*this"
          class="score-btn"
          size="mini"
          bindtap="onTapScoreQuestion"
          data-score="{{item}}"
        >
          提问{{item}}分
        </button>
      </view>
      <view wx:if="{{currentPublishedTest}}" class="event-list">
        <view class="lesson-header">
          <text class="lesson-title">当前单选题</text>
        </view>
        <view class="event-item">
          <view class="info">
            <text class="name">{{currentPublishedTest.testContent}}</text>
          </view>
          <view class="sub">
            <text>{{currentPublishedTest.displayType}}</text>
          </view>
          <view class="sub" wx:if="{{currentPublishedTest.testOptionsText}}">
            <text>{{currentPublishedTest.testOptionsText}}</text>
          </view>
          <view class="sub">
            <text>正确答案：{{currentPublishedTest.testCorrectAnswer || '-'}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{currentPublishedTest}}" class="event-list">
        <view class="lesson-header">
          <text class="lesson-title">当前题作答结果</text>
        </view>
        <view wx:if="{{currentTestRecords.length > 0}}">
          <view class="event-item" wx:for="{{currentTestRecords}}" wx:key="_id">
            <view class="info">
              <text class="name">{{item.studentName || item.studentId}}</text>
              <text class="event-score" wx:if="{{item.score}}">+{{item.score}}</text>
            </view>
            <view class="sub">
              <text>作答：{{item.testAnswer || '-'}}</text>
            </view>
            <view class="sub">
              <text>结果：{{item.testResult || item.testStatus || '-'}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="lesson-empty">当前题暂无学生作答</view>
      </view>
    </view>

    <view class="lesson-section">
      <view class="lesson-header">
        <text class="lesson-title">历史课次</text>
      </view>
      <scroll-view wx:if="{{lessons.length > 0}}" class="lesson-scroll" scroll-x="true" show-scrollbar="false">
        <view class="lesson-list">
          <view
            wx:for="{{lessons}}"
            wx:key="_id"
            class="lesson-item {{selectedLessonId === item._id ? 'active' : ''}}"
            bindtap="onSelectLesson"
            data-lesson-id="{{item._id}}"
          >
            <text class="lesson-item-title">课次 {{index + 1}}</text>
            <text class="lesson-item-id">{{item._id}}</text>
          </view>
        </view>
      </scroll-view>
      <view wx:else class="lesson-empty">暂无历史课次</view>
    </view>
  </view>

  <view class="list-container">
    <view class="event-list">
      <view class="lesson-header">
        <text class="lesson-title">本节互动记录</text>
      </view>

      <view wx:if="{{lessonEventsLoading}}" class="lesson-empty">互动记录加载中</view>

      <view wx:elif="{{lessonEvents.length > 0}}">
        <view class="event-item" wx:for="{{lessonEvents}}" wx:key="_id">
          <view class="info">
            <text class="name">{{item.studentName || (item.type === 'test_publish' ? '全班测试' : '未命名学生')}}</text>
            <text class="event-score" wx:if="{{item.score}}">+{{item.score}}</text>
          </view>
          <view class="sub">
            <text class="event-type">{{item.displayType}}</text>
          </view>
          <view class="sub" wx:if="{{(item.type === 'test_record' || item.type === 'test_publish') && item.testSummary}}">
            <text>{{item.testSummary}}</text>
          </view>
          <view class="sub" wx:if="{{(item.type === 'test_record' || item.type === 'test_publish') && item.testContent}}">
            <text>内容：{{item.testContent}}</text>
          </view>
          <view class="sub" wx:if="{{item.type === 'test_record' && item.testAnswer}}">
            <text>答案：{{item.testAnswer}}</text>
          </view>
          <view class="sub">
            <text>{{item.displayTime}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="lesson-empty">本节暂无互动记录</view>
    </view>
  </view>
</view>
