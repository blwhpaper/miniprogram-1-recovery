.interaction-page {
  align-items: stretch;
  padding-top: 0;
}

.interaction-hero {
  margin-bottom: 4rpx;
}

.interaction-hero__stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--ui-space-3);
}

.interaction-hero__stat {
  padding: 24rpx;
  border-radius: var(--ui-radius-sm);
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: #ffffff;
}

.interaction-hero__stat-label {
  font-size: var(--ui-font-xs);
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

.interaction-hero__stat-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.overview-card__row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--ui-space-3);
}

.overview-card__main {
  flex: 1;
  min-width: 0;
}

.overview-card__desc {
  margin-top: 10rpx;
  font-size: var(--ui-font-sm);
  line-height: 1.75;
  color: var(--ui-color-text-muted);
}

.overview-card__status {
  margin-top: 0;
}

.current-request-card,
.request-list-card,
.history-card,
.lesson-switch-card {
  margin-top: 0;
}

.request-item {
  gap: var(--ui-space-3);
}

.request-item--active {
  padding: 0;
  box-shadow: none;
  border-radius: 0;
}

.request-item__main {
  display: flex;
  align-items: center;
  gap: var(--ui-space-3);
}

.request-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--ui-color-primary-soft) 0%, #dbeafe 100%);
  border: 1rpx solid var(--ui-color-primary-border);
}

.request-avatar__img,
.request-avatar__fallback {
  width: 100%;
  height: 100%;
}

.request-avatar__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ui-color-primary);
}

.request-item__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.request-item__name {
  font-size: var(--ui-font-base);
  font-weight: 600;
  color: var(--ui-color-text);
}

.request-item__meta,
.request-item__time {
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.request-item__tag {
  align-self: flex-start;
  flex-shrink: 0;
}

.request-item__actions,
.score-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--ui-space-3);
}

.request-empty {
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}

.request-empty__lamp {
  position: relative;
  width: 140rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
}

.request-empty__lamp-body {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  bottom: 8rpx;
  height: 44rpx;
  border: 6rpx solid var(--ui-color-primary);
  border-radius: 40rpx 48rpx 32rpx 40rpx;
  background: rgba(255, 255, 255, 0.76);
}

.request-empty__lamp-glow {
  position: absolute;
  top: 0;
  right: 26rpx;
  width: 34rpx;
  height: 52rpx;
  border: 6rpx solid var(--ui-color-primary);
  border-radius: 26rpx 26rpx 28rpx 28rpx / 34rpx 34rpx 20rpx 20rpx;
  border-bottom: none;
  transform: rotate(8deg);
}

.ui-empty-desc {
  margin-top: 10rpx;
  font-size: var(--ui-font-sm);
  line-height: 1.7;
  color: var(--ui-color-text-muted);
}

.history-record-card {
  gap: 10rpx;
}

.test-score {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ui-color-success);
  align-self: flex-start;
}
