<view class="box">
  <view class="title">学生课堂</view>

  <view wx:if="{{shouldGoRegister}}" class="register-box">
    <view class="register-tip">当前状态：待绑定</view>
    <view class="register-tip">{{registerTipText}}</view>
    <button class="register-btn" type="primary" bindtap="goRegister">
      去绑定当前签到
    </button>
  </view>

  <view wx:if="{{hasBoundStudentSession && !signSuccess && !shouldGoRegister}}">
    <view class="leave-box">
      <text class="tip">当前状态：{{attendanceStatusText}}</text>
      <view wx:if="{{attendanceStatus === 'leave_agree'}}">本节课已被老师标记为请假，当前无需签到。</view>
      <view wx:elif="{{attendanceStatus === 'absent'}}">本节课已被老师标记为旷课，当前不可签到。</view>
      <view wx:elif="{{attendanceStatus === 'leave_wait'}}">当前请假状态待确认，暂不可继续签到。</view>
      <view wx:else>请确认当前学生身份无误后完成本次签到。</view>
    </view>
    <view class="input">
      <view>当前学生：{{name}}</view>
      <view>学号：{{studentId}}</view>
    </view>
    <button wx:if="{{attendanceStatus !== 'leave_agree' && attendanceStatus !== 'absent' && attendanceStatus !== 'leave_wait'}}" type="primary" bindtap="submitSign">确认签到</button>
  </view>

  <view wx:if="{{canInteract}}">
    <view class="leave-box">
      <text class="tip">当前状态：已签到，可参与课堂互动</text>
      <view wx:if="{{currentSingleChoiceTest}}">当前可用入口：单选题作答</view>
      <view wx:else>当前课堂互动入口会在老师发布后显示在下方。</view>
    </view>
    <view class="success">✅ 签到成功</view>

    <view class="leave-box">
      <text class="tip">请假申请</text>
      <view>当前为签到后代请假入口，请填写需请假的本班学生姓名。</view>
      <input
        class="leave-name-input"
        placeholder="请输入请假人姓名"
        value="{{leaveRequestTargetName}}"
        bindinput="onInputLeaveRequestTargetName"
      />
      <button bindtap="chooseLeaveRequestImage">上传假条图片</button>
      <image wx:if="{{leaveRequestImageTempPath}}" class="leave-img" src="{{leaveRequestImageTempPath}}" mode="aspectFill" />
      <button type="primary" bindtap="submitLeaveRequest">提交请假申请</button>
    </view>

    <view wx:if="{{currentSingleChoiceTest}}" class="leave-box">
      <text class="tip">当前单选题：{{currentSingleChoiceTest.testContent}}</text>
      <view wx:if="{{currentSingleChoiceTest.testOptions.length > 0}}">
        <button
          wx:for="{{currentSingleChoiceTest.testOptions}}"
          wx:key="value"
          data-answer="{{item.value}}"
          bindtap="onSelectSingleChoiceAnswer"
          disabled="{{hasSubmittedCurrentTest}}"
        >
          {{item.text}}{{selectedSingleChoiceAnswer === item.value ? '（已选）' : ''}}
        </button>
      </view>
      <view wx:if="{{hasSubmittedCurrentTest}}">
        已提交：{{currentTestRecord.payload.answer || selectedSingleChoiceAnswer || '-'}}
      </view>
      <button
        wx:if="{{!hasSubmittedCurrentTest}}"
        bindtap="submitSingleChoiceAnswer"
        type="primary"
      >
        提交单选题答案
      </button>
    </view>
  </view>
</view>

<button 
  wx:if="{{hasBoundStudentSession}}"
  bindtap="logout" 
  type="warn" 
  style="margin-top:60rpx;"
>
  退出登录
</button>
