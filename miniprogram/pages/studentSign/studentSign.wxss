/* 你原有样式不动，我只加新的 */
.leave-box {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.register-box {
  margin: 30rpx 0;
  padding: 28rpx 24rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 16rpx;
}

.register-tip {
  color: #ad4e00;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.register-btn {
  background: #fa8c16;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.question-box {
  margin-top: 32rpx;
  padding: 28rpx 24rpx;
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 16rpx;
}

.question-tip {
  color: #237804;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.question-status {
  color: #389e0d;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.question-apply-btn {
  background: #52c41a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}
