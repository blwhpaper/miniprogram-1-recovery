/* 你原有样式不动，我只加新的 */
.leave-box {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.register-box {
  margin: 30rpx 0;
  padding: 28rpx 24rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 16rpx;
}

.register-tip {
  color: #ad4e00;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.register-btn {
  background: #fa8c16;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.question-box {
  margin-top: 32rpx;
  padding: 28rpx 24rpx;
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 16rpx;
}

.question-tip {
  color: #237804;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.question-status {
  color: #389e0d;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.question-apply-btn {
  background: #52c41a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.leave-img {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.leave-name-input {
  margin: 20rpx 0;
  padding: 20rpx 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  background: #fff;
}

.leave-step {
  margin-top: 20rpx;
  color: #262626;
  font-size: 28rpx;
  font-weight: 600;
}

.leave-feedback {
  margin: 16rpx 0 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  background: #fafafa;
  color: #595959;
}

.leave-feedback--empty,
.leave-feedback--idle {
  background: #fafafa;
  color: #595959;
}

.leave-feedback--matched {
  background: #f6ffed;
  color: #237804;
}

.leave-feedback--not_found,
.leave-feedback--duplicate,
.leave-feedback--self,
.leave-feedback--invalid {
  background: #fff2f0;
  color: #cf1322;
}

.leave-summary,
.leave-result,
.leave-result-card {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  color: #262626;
  font-size: 26rpx;
  line-height: 1.8;
}

.leave-result__title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}
