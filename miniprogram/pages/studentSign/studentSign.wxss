/* 你原有样式不动，我只加新的 */
.leave-box {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}
.tip {
  display: block;
  text-align: center;
  color: #ff6600;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}
.leave-btn {
  background: #722ED1;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.register-box {
  margin: 30rpx 0;
  padding: 28rpx 24rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 16rpx;
}

.register-tip {
  color: #ad4e00;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.register-btn {
  background: #fa8c16;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 只新增这个假条提示样式 */
.leave-tip {
  background: #e6f7ff;
  color: #0099ff;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  margin: 20rpx 0;
}
